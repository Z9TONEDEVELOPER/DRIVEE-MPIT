<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NexusDataSpace.Desktop.App"
             xmlns:local="using:NexusDataSpace.Desktop"
             xmlns:desktop="clr-namespace:NexusDataSpace.Desktop"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <desktop:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />

        <!-- ════════════════════════════════════════════════════
             NEXUS DATA SPACE — GLOBAL STYLES
             Цвета совпадают с Web app.css
             ════════════════════════════════════════════════════ -->
        <Style Selector="Window">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="FontFamily" Value="Segoe UI, Arial, sans-serif"/>
        </Style>

        <Style Selector="Border.bi-logo">
            <Setter Property="Background" Value="#0A1324"/>
            <Setter Property="BorderBrush" Value="#7700D1FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="BoxShadow" Value="0 0 22 0 #3300D1FF"/>
        </Style>

        <Style Selector="Border.user-card">
            <Setter Property="Background" Value="#111A2E"/>
            <Setter Property="BorderBrush" Value="#333B82F6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="BoxShadow" Value="0 18 45 0 #33000000"/>
        </Style>

        <Style Selector="Border.avatar">
            <Setter Property="Background" Value="#0A1324"/>
            <Setter Property="BorderBrush" Value="#7700D1FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="BoxShadow" Value="0 0 18 0 #3300D1FF"/>
        </Style>

        <!-- ── Кнопка сброса стиля ─────────────────────────────── -->
        <Style Selector="Button.flat">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- ── Основная индиго-кнопка ─────────────────────────── -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#6600D1FF"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#06B6D4"/>
        </Style>
        <Style Selector="Button.primary:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#cbd5e1"/>
        </Style>

        <Style Selector="Button.new-chat">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#6600D1FF"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.new-chat:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#06B6D4"/>
        </Style>

        <Style Selector="Button.logout-btn">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#14FFFFFF"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <!-- ── Ghost-кнопка ────────────────────────────────────── -->
        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="#08FFFFFF"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#14FFFFFF"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A3A55"/>
        </Style>

        <!-- ── Зелёная кнопка сохранения ──────────────────────── -->
        <Style Selector="Button.save">
            <Setter Property="Background" Value="#22C55E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.save:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#059669"/>
        </Style>

        <!-- ── Send-кнопка чата ────────────────────────────────── -->
        <Style Selector="Button.send">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#6600D1FF"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.send:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#06B6D4"/>
        </Style>
        <Style Selector="Button.send:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#cbd5e1"/>
        </Style>

        <!-- ── Шаблон-кнопка в сайдбаре ──────────────────────── -->
        <Style Selector="Button.template-btn">
            <Setter Property="Background" Value="#08FFFFFF"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#14FFFFFF"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.template-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A3A55"/>
        </Style>

        <!-- ── Навигация в сайдбаре ───────────────────────────── -->
        <Style Selector="Button.nav-link">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.nav-link:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E293B"/>
        </Style>
        <Style Selector="Button.nav-link.active /template/ ContentPresenter">
            <Setter Property="Background" Value="#263B82F6"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#773B82F6"/>
        </Style>

        <!-- ── Кнопка отчёта в сайдбаре ──────────────────────── -->
        <Style Selector="Button.report-link">
            <Setter Property="Background" Value="#08FFFFFF"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#14FFFFFF"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.report-link:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A3A55"/>
        </Style>

        <Style Selector="Button.report-delete">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.report-delete:pointerover /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="#ef4444"/>
        </Style>

        <!-- ── Таб визуализации ───────────────────────────────── -->
        <Style Selector="Button.viz-tab">
            <Setter Property="Background" Value="#08FFFFFF"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#14FFFFFF"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.viz-tab.active /template/ ContentPresenter">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>

        <!-- ── Insight-таб (reasoning/sql) ───────────────────── -->
        <Style Selector="Button.insight-tab">
            <Setter Property="Background" Value="#08FFFFFF"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#14FFFFFF"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.insight-tab.active /template/ ContentPresenter">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.welcome-example">
            <Setter Property="Background" Value="#08FFFFFF"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#14FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="8,14"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.welcome-example:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A3A55"/>
            <Setter Property="BorderBrush" Value="#6600D1FF"/>
            <Setter Property="TextElement.Foreground" Value="#F8FAFC"/>
        </Style>

        <Style Selector="Button.table-action">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#6600D1FF"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="5,12"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.table-action.ghost">
            <Setter Property="Background" Value="#08FFFFFF"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#14FFFFFF"/>
        </Style>
        <Style Selector="Button.table-action.ghost:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A3A55"/>
            <Setter Property="BorderBrush" Value="#6600D1FF"/>
            <Setter Property="TextElement.Foreground" Value="#F8FAFC"/>
        </Style>

        <!-- ── TextBox стили ──────────────────────────────────── -->
        <Style Selector="TextBox.chat-input">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style Selector="TextBox.chat-input:focus /template/ Border">
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="TextBox.report-name-input">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#14FFFFFF"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
        </Style>

        <Style Selector="Border.chat-header">
            <Setter Property="Background" Value="#DD0B1220"/>
            <Setter Property="BorderBrush" Value="#10FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="28,16"/>
        </Style>

        <Style Selector="Border.chat-input-area">
            <Setter Property="Background" Value="#EE0B1220"/>
            <Setter Property="BorderBrush" Value="#10FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="Padding" Value="28,14,28,10"/>
        </Style>

        <Style Selector="Border.chat-input-wrap">
            <Setter Property="Background" Value="#05FFFFFF"/>
            <Setter Property="BorderBrush" Value="#7700D1FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="14,6,6,6"/>
            <Setter Property="MaxWidth" Value="960"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="BoxShadow" Value="0 0 28 0 #333B82F6"/>
        </Style>

        <Style Selector="StackPanel.chat-welcome">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MaxWidth" Value="720"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style Selector="Border.welcome-panel">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="28,12"/>
            <Setter Property="Padding" Value="32,28"/>
            <Setter Property="MaxWidth" Value="1140"/>
            <Setter Property="Background" Value="#05FFFFFF"/>
            <Setter Property="BorderBrush" Value="#7700D1FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="BoxShadow" Value="0 0 30 0 #333B82F6"/>
        </Style>

        <Style Selector="Border.welcome-icon">
            <Setter Property="Background" Value="#0A1324"/>
            <Setter Property="BorderBrush" Value="#7700D1FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Width" Value="86"/>
            <Setter Property="Height" Value="86"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="BoxShadow" Value="0 0 22 0 #3300D1FF"/>
        </Style>

        <Style Selector="Grid.message-row">
            <Setter Property="MaxWidth" Value="960"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="28,0"/>
        </Style>

        <Style Selector="Border.bot-bubble">
            <Setter Property="Background" Value="#111A2E"/>
            <Setter Property="BorderBrush" Value="#0DFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4,14,14,14"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>

        <Style Selector="Border.result-bubble">
            <Setter Property="Background" Value="#111A2E"/>
            <Setter Property="BorderBrush" Value="#0DFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4,14,14,14"/>
        </Style>

        <Style Selector="StackPanel.result-card">
            <Setter Property="Margin" Value="16,14,16,0"/>
        </Style>

        <Style Selector="StackPanel.viz-card">
            <Setter Property="Margin" Value="16,14,16,14"/>
        </Style>

        <Style Selector="Grid.save-row">
            <Setter Property="Background" Value="#111A2E"/>
            <Setter Property="Margin" Value="0,14,0,0"/>
        </Style>

        <Style Selector="Border.thinking-bubble">
            <Setter Property="MinHeight" Value="36"/>
        </Style>

        <Style Selector="Border.typing-dot">
            <Setter Property="Background" Value="#38BDF8"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Height" Value="6"/>
        </Style>

        <Style Selector="Border.empty-card">
            <Setter Property="Background" Value="#111A2E"/>
            <Setter Property="BorderBrush" Value="#14FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="30"/>
        </Style>

        <Style Selector="Border.reports-card">
            <Setter Property="Background" Value="#111A2E"/>
            <Setter Property="BorderBrush" Value="#14FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style Selector="Border.login-card">
            <Setter Property="Background" Value="#111A2E"/>
            <Setter Property="BorderBrush" Value="#333B82F6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="28"/>
            <Setter Property="BoxShadow" Value="0 24 60 0 #66000000"/>
        </Style>

        <Style Selector="TextBox.login-input">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#14FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#14FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#663B82F6"/>
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#14FFFFFF"/>
        </Style>

        <Style Selector="DataGrid">
            <Setter Property="Background" Value="#111A2E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#0DFFFFFF"/>
        </Style>

        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style Selector="DataGridCell">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
        </Style>

        <!-- ── ScrollViewer ──────────────────────────────────── -->
        <Style Selector="ScrollViewer">
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
    </Application.Styles>
</Application>

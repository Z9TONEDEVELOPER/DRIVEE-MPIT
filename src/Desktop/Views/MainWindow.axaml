<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:NexusDataSpace.Desktop.ViewModels"
        xmlns:views="clr-namespace:NexusDataSpace.Desktop.Views"
        mc:Ignorable="d"
        x:Class="NexusDataSpace.Desktop.Views.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Title="Nexus Data Space · NL → SQL аналитика"
        Width="1280" Height="800"
        MinWidth="980" MinHeight="640"
        WindowStartupLocation="CenterScreen">
    <Design.DataContext>
        <viewModels:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="280,*" Background="#0B1220">
        <Border Grid.Column="0"
                Background="#0E1628"
                Padding="14,18">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Classes="bi-logo">
                            <Image Source="avares://NexusDataSpace.Desktop/Assets/Icons/logo-NEXUS-mark.png"
                                   Stretch="Uniform"
                                   Margin="7"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Nexus Data Space"
                                       Foreground="#F8FAFC"
                                       FontWeight="Bold"
                                       FontSize="15"/>
                            <TextBlock Text="NL → SQL аналитика"
                                       Foreground="#94A3B8"
                                       FontSize="11"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Classes="user-card">
                        <StackPanel Spacing="8">
                            <TextBlock Text="СЕАНС"
                                       Foreground="#94A3B8"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       LetterSpacing="1"/>
                            <TextBlock Text="{Binding DisplayName}"
                                       Foreground="#F8FAFC"
                                       FontSize="15"
                                       FontWeight="Bold"/>
                            <TextBlock Foreground="#CBD5E1"
                                       FontSize="12"
                                       TextWrapping="Wrap">
                                <Run Text="{Binding Username}"/>
                                <Run Text=" · "/>
                                <Run Text="Desktop клиент"/>
                            </TextBlock>
                            <Button Classes="logout-btn"
                                    Content="Выйти"
                                    Command="{Binding LogoutCommand}"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Spacing="2">
                        <Button Classes="nav-link"
                                Classes.active="{Binding IsWorkspacePage}"
                                Content="◈  Workspace"
                                HorizontalAlignment="Stretch"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="workspace"/>
                        <Button Classes="nav-link"
                                Classes.active="{Binding IsReportsPage}"
                                Content="▤  Отчёты"
                                HorizontalAlignment="Stretch"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="reports"/>
                        <Button Classes="nav-link"
                                Classes.active="{Binding IsUsersPage}"
                                Content="☰  Пользователи"
                                HorizontalAlignment="Stretch"
                                IsVisible="{Binding IsAdmin}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="users"/>
                    </StackPanel>

                    <Button Content="＋  Новый чат"
                            Classes="new-chat"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Command="{Binding NewChatCommand}"/>
                </StackPanel>

                <ScrollViewer DockPanel.Dock="Bottom" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12" Margin="0,16,0,0">
                        <TextBlock Text="ШАБЛОНЫ ЗАПРОСОВ"
                                   Foreground="#94A3B8"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   LetterSpacing="1"/>
                        <ItemsControl ItemsSource="{Binding Chat.Templates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}"
                                            Classes="template-btn"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,0,0,6"
                                            Command="{Binding $parent[Window].DataContext.Chat.UseTemplateCommand}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="СОХРАНЁННЫЕ ОТЧЁТЫ"
                                   Foreground="#94A3B8"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   LetterSpacing="1"
                                   Margin="0,8,0,0"/>

                        <TextBlock Text="Тут будут появляться ваши сохраненные отчеты"
                                   Foreground="#94A3B8"
                                   FontSize="12"
                                   FontStyle="Italic"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding Chat.Reports.Count, Converter={x:Static views:Converters.IsZeroConverter}}"/>

                        <ItemsControl ItemsSource="{Binding Chat.Reports}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                                        <Button Grid.Column="0"
                                                Content="{Binding Name}"
                                                Classes="report-link"
                                                HorizontalAlignment="Stretch"
                                                Command="{Binding $parent[Window].DataContext.OpenReportFromListCommand}"
                                                CommandParameter="{Binding}"/>
                                        <Button Grid.Column="1"
                                                Content="×"
                                                Classes="report-delete"
                                                Command="{Binding $parent[Window].DataContext.DeleteReportFromListCommand}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <DockPanel Background="#0B1220"
                       IsVisible="{Binding IsWorkspacePage}">
                <Border DockPanel.Dock="Top"
                        Classes="chat-header">
                    <StackPanel>
                        <TextBlock Text="Чат с данными"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#F8FAFC"/>
                        <TextBlock Text="Спросил → система поняла → построила SQL → показала результат"
                                   FontSize="12"
                                   Foreground="#94A3B8"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Bottom"
                        Classes="chat-input-area">
                    <StackPanel>
                        <Border Classes="chat-input-wrap">
                            <Grid ColumnDefinitions="*,44">
                                <TextBox Grid.Column="0"
                                         x:Name="ChatInputBox"
                                         Classes="chat-input"
                                         Text="{Binding Chat.InputText}"
                                         Watermark="Спросите у данных… (Enter — отправить, Shift+Enter — новая строка)"
                                         IsEnabled="{Binding !Chat.IsBusy}"
                                         KeyDown="ChatInput_KeyDown"
                                         MaxHeight="200"/>
                                <Button Grid.Column="1"
                                        Classes="send"
                                        Content="➤"
                                        VerticalAlignment="Bottom"
                                        IsEnabled="{Binding !Chat.IsBusy}"
                                        Command="{Binding Chat.SendCommand}"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="Вы задаёте вопрос — система сама находит нужные данные и визуализирует результат (работает только с чтением данных)"
                                   FontSize="11"
                                   Foreground="#94A3B8"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <ScrollViewer x:Name="ChatScrollViewer"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="18" Margin="0,24">
                        <Border Classes="welcome-panel"
                                IsVisible="{Binding Chat.IsEmpty}">
                            <StackPanel Classes="chat-welcome">
                                <Border Classes="welcome-icon">
                                    <Image Source="avares://NexusDataSpace.Desktop/Assets/Icons/logo-NEXUS-mark.png"
                                           Stretch="Uniform"
                                           Margin="13"/>
                                </Border>
                                <TextBlock Text="Привет! Я аналитический ассистент Nexus Data Space"
                                           FontSize="26"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="#F8FAFC"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="Спросите что угодно про заказы, выручку, отмены или поведение пользователей. Я сама интерпретирую запрос, построю безопасный SQL и покажу результат."
                                           FontSize="14"
                                           Foreground="#94A3B8"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Margin="0,0,0,22"/>
                                <ItemsControl ItemsSource="{Binding Chat.Templates}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel HorizontalAlignment="Center"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding}"
                                                    Classes="welcome-example"
                                                    Margin="7"
                                                    Command="{Binding $parent[Window].DataContext.Chat.RunTemplateCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <ItemsControl ItemsSource="{Binding Chat.Messages}"
                                      IsVisible="{Binding !Chat.IsEmpty}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <views:ChatMessageView Margin="0,0,0,18"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Classes="message-row"
                              IsVisible="{Binding Chat.IsBusy}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Classes="avatar">
                                    <Image Source="avares://NexusDataSpace.Desktop/Assets/Icons/logo-NEXUS-mark.png"
                                           Stretch="Uniform"
                                           Margin="7"/>
                                </Border>
                                <Border Classes="bot-bubble thinking-bubble">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                                            <Border Classes="typing-dot"/>
                                            <Border Classes="typing-dot"/>
                                            <Border Classes="typing-dot"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Chat.ThinkingLabel}"
                                                   Foreground="#94A3B8"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>

            <DockPanel Background="#0B1220"
                       IsVisible="{Binding IsReportsPage}">
                <Border DockPanel.Dock="Top"
                        Classes="chat-header">
                    <StackPanel>
                        <TextBlock Text="Сохранённые отчёты"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#F8FAFC"/>
                        <TextBlock Text="Desktop показывает те же отчёты, которые сохраняются через общий Core/API контракт."
                                   FontSize="12"
                                   Foreground="#94A3B8"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Grid Margin="28,24">
                    <Border Classes="empty-card"
                            IsVisible="{Binding Chat.Reports.Count, Converter={x:Static views:Converters.IsZeroConverter}}">
                        <TextBlock Text="Пока нет сохранённых отчётов. Перейдите в Workspace и создайте первый."
                                   Foreground="#94A3B8"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Border Classes="reports-card"
                            IsVisible="{Binding Chat.Reports.Count, Converter={x:Static views:Converters.IsNotZeroConverter}}">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <DataGrid ItemsSource="{Binding Chat.Reports}"
                                      AutoGenerateColumns="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      BorderThickness="0"
                                      Background="#111A2E"
                                      CanUserReorderColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserSortColumns="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="64"/>
                                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="220"/>
                                    <DataGridTextColumn Header="Запрос" Binding="{Binding UserQuery}" Width="*"/>
                                    <DataGridTextColumn Header="Визуализация" Binding="{Binding Visualization}" Width="130"/>
                                    <DataGridTextColumn Header="Автор" Binding="{Binding Author}" Width="120"/>
                                    <DataGridTemplateColumn Header="Создан" Width="160">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding CreatedAt, Converter={x:Static views:Converters.LocalDateTimeConverter}}"
                                                           VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="" Width="170">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Button Content="Открыть"
                                                            Classes="table-action"
                                                            Command="{Binding $parent[Window].DataContext.OpenReportFromListCommand}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="Удалить"
                                                            Classes="table-action ghost"
                                                            Command="{Binding $parent[Window].DataContext.DeleteReportFromListCommand}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </DockPanel>

            <DockPanel Background="#0B1220"
                       IsVisible="{Binding IsUsersPage}">
                <Border DockPanel.Dock="Top"
                        Classes="chat-header">
                    <StackPanel>
                        <TextBlock Text="Пользователи"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#F8FAFC"/>
                        <TextBlock Text="Админский контур Desktop использует тот же UserService и заявки, что и Web."
                                   FontSize="12"
                                   Foreground="#94A3B8"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="28,24" Spacing="18">
                        <Border Background="#2A1119"
                                BorderBrush="#7F1D1D"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,8"
                                IsVisible="{Binding AdminError, Converter={x:Static views:Converters.IsNotNullConverter}}">
                            <TextBlock Text="{Binding AdminError}"
                                       Foreground="#FCA5A5"
                                       FontSize="12.5"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Border Background="#0D2418"
                                BorderBrush="#14532D"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,8"
                                IsVisible="{Binding AdminNotice, Converter={x:Static views:Converters.IsNotNullConverter}}">
                            <TextBlock Text="{Binding AdminNotice}"
                                       Foreground="#22C55E"
                                       FontSize="12.5"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Border Classes="reports-card">
                            <StackPanel Margin="16,14" Spacing="4">
                                <TextBlock Text="Компания"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="#F8FAFC"/>
                                <TextBlock Text="{Binding CompanyLabel}"
                                           FontSize="12.5"
                                           Foreground="#94A3B8"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Classes="reports-card">
                            <StackPanel Spacing="14" Margin="16,14">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel>
                                        <TextBlock Text="LLM provider"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="#F8FAFC"/>
                                        <TextBlock Text="Выбор между локальным сервером и GigaChat. Ключ можно заменить, существующий ключ не показывается."
                                                   FontSize="12"
                                                   Foreground="#94A3B8"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="Сохранить"
                                            Classes="table-action"
                                            IsEnabled="{Binding !IsSavingLlmSettings}"
                                            Command="{Binding SaveLlmSettingsCommand}"/>
                                </Grid>

                                <Grid ColumnDefinitions="260,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="16" RowSpacing="10">
                                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                                        <TextBlock Text="Провайдер"
                                                   Foreground="#94A3B8"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                        <ComboBox ItemsSource="{Binding LlmProviderOptions}"
                                                  SelectedItem="{Binding SelectedLlmProvider}"
                                                  IsEnabled="{Binding !IsSavingLlmSettings}"
                                                  HorizontalAlignment="Stretch"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                        <TextBlock Text="Сейчас выбран"
                                                   Foreground="#94A3B8"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CurrentLlmProviderLabel}"
                                                   Foreground="#F8FAFC"
                                                   FontSize="14"
                                                   FontWeight="Bold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                        <TextBlock Text="Локальный сервер"
                                                   Foreground="#94A3B8"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding LocalLlmLabel}"
                                                   Foreground="#E2E8F0"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                        <TextBlock Text="GigaChat"
                                                   Foreground="#94A3B8"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding GigaChatLabel}"
                                                   Foreground="#E2E8F0"
                                                   FontSize="12"/>
                                        <TextBlock Text="{Binding GigaChatSecretStatus}"
                                                   Foreground="#22C55E"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="6">
                                        <TextBlock Text="GigaChat AuthorizationKey"
                                                   Foreground="#94A3B8"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                        <TextBox Text="{Binding GigaChatAuthorizationKey, Mode=TwoWay}"
                                                 PasswordChar="*"
                                                 Watermark="Новый ключ, если нужно заменить"
                                                 IsEnabled="{Binding !IsSavingLlmSettings}"/>
                                        <TextBlock Text="При сохранении ключ шифруется в metadata DB и не возвращается обратно в UI."
                                                   Foreground="#94A3B8"
                                                   FontSize="11.5"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="reports-card">
                            <StackPanel>
                                <Grid ColumnDefinitions="*,Auto" Margin="16,14">
                                    <StackPanel>
                                        <TextBlock Text="Заявки на доступ"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="#F8FAFC"/>
                                        <TextBlock Text="Ожидают решения администратора"
                                                   FontSize="12"
                                                   Foreground="#94A3B8"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="Обновить"
                                            Classes="table-action ghost"
                                            Command="{Binding LoadAdminCommand}"/>
                                </Grid>

                                <TextBlock Text="Новых заявок нет"
                                           Foreground="#94A3B8"
                                           FontSize="13"
                                           TextAlignment="Center"
                                           Margin="16,0,16,16"
                                           IsVisible="{Binding PendingRegistrations.Count, Converter={x:Static views:Converters.IsZeroConverter}}"/>

                                <DataGrid ItemsSource="{Binding PendingRegistrations}"
                                          AutoGenerateColumns="False"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column"
                                          BorderThickness="0"
                                          IsVisible="{Binding PendingRegistrations.Count, Converter={x:Static views:Converters.IsNotZeroConverter}}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="64"/>
                                        <DataGridTextColumn Header="Имя" Binding="{Binding DisplayName}" Width="180"/>
                                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220"/>
                                        <DataGridTextColumn Header="Организация" Binding="{Binding Organization}" Width="180"/>
                                        <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="*"/>
                                        <DataGridTemplateColumn Header="" Width="170">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <Button Content="Одобрить"
                                                                Classes="table-action"
                                                                Command="{Binding $parent[Window].DataContext.ApproveRegistrationCommand}"
                                                                CommandParameter="{Binding}"/>
                                                        <Button Content="Отклонить"
                                                                Classes="table-action ghost"
                                                                Command="{Binding $parent[Window].DataContext.RejectRegistrationCommand}"
                                                                CommandParameter="{Binding}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <Border Classes="reports-card">
                            <StackPanel>
                                <TextBlock Text="Пользователи"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="#F8FAFC"
                                           Margin="16,14"/>
                                <DataGrid ItemsSource="{Binding Users}"
                                          AutoGenerateColumns="False"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column"
                                          BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="64"/>
                                        <DataGridTextColumn Header="Имя" Binding="{Binding DisplayName}" Width="220"/>
                                        <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="180"/>
                                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220"/>
                                        <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="110"/>
                                        <DataGridTextColumn Header="Активен" Binding="{Binding IsActive}" Width="90"/>
                                        <DataGridTextColumn Header="Отчётов" Binding="{Binding ReportCount}" Width="100"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Grid>

        <Border Grid.ColumnSpan="2"
                Background="#0B1220"
                IsVisible="{Binding !IsAuthenticated}">
            <Grid>
                <Border Classes="login-card"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel Spacing="14" Width="380">
                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                            <Border Classes="welcome-icon" Margin="0">
                                <Image Source="avares://NexusDataSpace.Desktop/Assets/Icons/logo-NEXUS-mark.png"
                                       Stretch="Uniform"
                                       Margin="13"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Nexus Data Space"
                                           Foreground="#F8FAFC"
                                           FontSize="22"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Вход в Desktop"
                                           Foreground="#94A3B8"
                                           FontSize="13"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="Используйте ту же учетную запись, что и в Web."
                                   Foreground="#94A3B8"
                                   FontSize="13"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Логин"
                                       Foreground="#94A3B8"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                            <TextBox Classes="login-input"
                                     Text="{Binding LoginUsername}"
                                     IsEnabled="{Binding !IsLoggingIn}"/>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Пароль"
                                       Foreground="#94A3B8"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                            <TextBox Classes="login-input"
                                     Text="{Binding LoginPassword}"
                                     PasswordChar="•"
                                     IsEnabled="{Binding !IsLoggingIn}"
                                     KeyDown="LoginPassword_KeyDown"/>
                        </StackPanel>

                        <Border Background="#2A1119"
                                BorderBrush="#7F1D1D"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,8"
                                IsVisible="{Binding LoginError, Converter={x:Static views:Converters.IsNotNullConverter}}">
                            <TextBlock Text="{Binding LoginError}"
                                       Foreground="#FCA5A5"
                                       FontSize="12.5"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Button Classes="primary"
                                Content="Войти"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                IsEnabled="{Binding !IsLoggingIn}"
                                Command="{Binding LoginCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DriveeDataSpace.Desktop.ViewModels"
        xmlns:controls="using:ScottPlot.Avalonia"
        xmlns:converters="using:DriveeDataSpace.Desktop.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="DriveeDataSpace.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="DriveeDataSpace.Desktop">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>
<DockPanel>
        <!-- Верхняя панель -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="10">
            <TextBox Text="{Binding QueryText}" PlaceholderText="Задайте вопрос на естественном языке..."
                     MinWidth="600" IsReadOnly="{Binding IsLoading}"
                     KeyDown="TextBox_KeyDown"/>
            <Button Content="▶ Выполнить" Command="{Binding ExecuteQueryCommand}"
                    IsEnabled="{Binding !IsLoading}" Width="120"/>
            <Button Content="💾 Сохранить" Command="{Binding SaveReportCommand}" Width="110"/>
            <ComboBox ItemsSource="{Binding ChartTypes}" SelectedItem="{Binding ChartType}" Width="80" 
                      Margin="20,0,0,0"/>
        </StackPanel>

        <!-- Статус-бар -->
        <ProgressBar DockPanel.Dock="Top" Height="4" Value="{Binding IsLoading, Converter={StaticResource BoolToProgressValue}}" 
                     IsIndeterminate="{Binding IsLoading}" Margin="0,0,0,10"/>
        <TextBlock DockPanel.Dock="Top" Text="{Binding Status}" FontSize="14" Margin="10,5"/>

        <Grid ColumnDefinitions="250,*,300">
            <!-- Левая панель: Отчёты -->
            <ListBox Grid.Column="0" ItemsSource="{Binding SavedReports}" Margin="10" SelectionMode="Single">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Intent.Metric}" Command="{Binding DataContext.RerunReportCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" 
                                CommandParameter="{Binding}" HorizontalContentAlignment="Left" Margin="2"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Центр: Результат -->
            <TabControl Grid.Column="1" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
                <TabItem Header="📊 Таблица">
                    <DataGrid ItemsSource="{Binding LastResult.ResultTable}" AutoGenerateColumns="True" Margin="10"/>
                </TabItem>
                <TabItem Header="📈 График">
                    <controls:AvaPlot x:Name="PlotControl" Margin="10"/>
                </TabItem>
                <TabItem Header="🔍 SQL">
                    <TextBox Text="{Binding LastResult.FinalSql}" IsReadOnly="True" TextWrapping="Wrap" 
                             FontFamily="monospace" Margin="10"/>
                </TabItem>
                <TabItem Header="📖 Explain">
                    <ScrollViewer Margin="10">
                        <StackPanel>
                            <TextBlock Text="🟢 Для бизнеса:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding LastResult.Explain.BusinessExplanation}" TextWrapping="Wrap" Margin="0,0,0,15"/>
                            <TextBlock Text="🔧 Технически:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding LastResult.Explain.TechnicalExplanation}" TextWrapping="Wrap" FontFamily="monospace"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!-- Правая панель: Быстрые шаблоны -->
            <StackPanel Grid.Column="2" Margin="10">
                <TextBlock Text="⚡ Быстрые шаблоны" FontWeight="Bold" Margin="0,0,0,10"/>
                <Button Content="Выручка за 2024 vs 2025" Command="{Binding SetQueryCommand}" CommandParameter="Покажи выручку за этот год и прошлый и сравни" Margin="0,5"/>
                <Button Content="Средний чек по городам" Command="{Binding SetQueryCommand}" CommandParameter="Средний чек поездки с группировкой по городу" Margin="0,5"/>
                <Button Content="Количество поездок за месяц" Command="{Binding SetQueryCommand}" CommandParameter="Количество поездок за последний месяц" Margin="0,5"/>
            </StackPanel>
        </Grid>
    </DockPanel>
    
</Window>

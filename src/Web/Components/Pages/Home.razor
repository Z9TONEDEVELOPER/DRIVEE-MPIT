@page "/"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.Text.Json
@using global::DriveeDataSpace.Core.Models
@using global::DriveeDataSpace.Web.Models
@using global::DriveeDataSpace.Core.Services
@using global::DriveeDataSpace.Web.Services
@inject NlSqlEngine Engine
@inject ReportService Reports
@inject AuditLogService Audit
@inject IJSRuntime JS
@inject WorkspaceSessionState WorkspaceState
@inject AuthenticationStateProvider AuthenticationStateProvider
@implements IDisposable

<PageTitle>Drivee BI · Чат с данными</PageTitle>

<div class="bi-workspace">
    <aside class="bi-sidebar">
        <div class="bi-brand">
            <div class="bi-logo">◆</div>
            <div>
                <div class="bi-brand-title">Drivee BI</div>
                <div class="bi-brand-sub">NL → SQL аналитика</div>
            </div>
        </div>

        <div class="bi-user-card">
            <div class="bi-user-label">Сеанс</div>
            <div class="bi-user-name">@_displayName</div>
            <div class="bi-user-meta">@_username · @(_isAdmin ? "Администратор" : "Пользователь")</div>
            <form method="post" action="/auth/logout">
                <button type="submit" class="bi-logout-btn">Выйти</button>
            </form>
        </div>

        <SidebarNav Current="workspace" IsAdmin="_isAdmin" />

        <button class="bi-new-chat" @onclick="ClearChat">＋ Новый чат</button>

        <div class="bi-section-title">Шаблоны запросов</div>
        <div class="bi-templates">
            @foreach (var t in _templates)
            {
                <button class="bi-template" @onclick="() => UseTemplate(t)">@t</button>
            }
        </div>

        <div class="bi-section-title">Сохранённые отчёты</div>
        <div class="bi-reports-list">
            @if (_reports.Count == 0)
            {
                <div class="bi-muted">Тут будут появляться ваши сохраненные отчеты </div>
            }
            else
            {
                @foreach (var r in _reports)
                {
                    <div class="bi-report-item">
                        <button class="bi-report-link" @onclick="() => OpenReport(r.Id)" title="@r.UserQuery">
                            @r.Name
                        </button>
                        <button class="bi-report-del" @onclick="() => DeleteReport(r.Id)" title="Удалить">×</button>
                    </div>
                }
            }
        </div>
    </aside>

    <main class="bi-chat-main">
        <header class="bi-chat-header">
            <div>
                <h1>Чат с данными</h1>
                <div class="bi-tagline">Спросил → система поняла → построила SQL → показала результат</div>
            </div>
        </header>

        <div id="bi-chat-log" class="bi-chat-log">
            @if (_messages.Count == 0)
            {
                <div class="bi-chat-welcome">
                    <div class="bi-welcome-icon">◆</div>
                    <h2>Привет! Я BI-ассистент Drivee</h2>
                    <p>Спросите что угодно про заказы, выручку, отмены или поведение пользователей. Я сама интерпретирую запрос, построю безопасный SQL и покажу результат.</p>
                    <div class="bi-welcome-examples">
                        @foreach (var t in _templates.Take(4))
                        {
                            <button class="bi-welcome-ex" @onclick="() => RunQuery(t)">@t</button>
                        }
                    </div>
                </div>
            }

            @foreach (var m in _messages)
            {
                @if (m.Role == "user")
                {
                    <div class="bi-msg bi-msg-user">
                        <div class="bi-bubble bi-bubble-user">@m.Text</div>
                    </div>
                }
                else if (m.Role == "chat")
                {
                    <div class="bi-msg bi-msg-bot">
                        <div class="bi-avatar">◆</div>
                        <div class="bi-bubble bi-bubble-bot">
                            @foreach (var line in (m.Text ?? "").Split('\n'))
                            {
                                <p>@line</p>
                            }
                        </div>
                    </div>
                }
                else if (m.Role == "result" && m.Result != null)
                {
                    <div class="bi-msg bi-msg-bot">
                        <div class="bi-avatar">◆</div>
                        <div class="bi-bubble bi-bubble-result">
                            @RenderResult(m)
                        </div>
                    </div>
                }
            }

            @if (_busy)
            {
                <div class="bi-msg bi-msg-bot">
                    <div class="bi-avatar">◆</div>
                    <div class="bi-bubble bi-bubble-bot bi-thinking">
                        <span class="bi-typing"><span></span><span></span><span></span></span>
                        <span>@_thinkingLabel</span>
                    </div>
                </div>
            }
        </div>

        <div class="bi-chat-input-area">
            <div class="bi-chat-input-wrap">
                <textarea class="bi-chat-input"
                          @bind="_query"
                          @bind:event="oninput"
                          @onkeydown="OnKeyDown"
                          placeholder="Спросите у данных… (Enter — отправить, Shift+Enter — новая строка)"
                          rows="1"></textarea>
                <button class="bi-send" @onclick="Send" aria-disabled="@_busy" title="Отправить">
                    @if (_busy)
                    {
                        <span>…</span>
                    }
                    else
                    {
                        <span>➤</span>
                    }
                </button>
            </div>
            <div class="bi-chat-hint">Вы задаёте вопрос — система сама находит нужные данные и визуализирует результат (работает только с чтением данных)</div>
        </div>
    </main>
</div>

@code {
    private const string ReasoningTab = "reasoning";
    private const string SqlTab = "sql";

    private string _query
    {
        get => WorkspaceState.Query;
        set => WorkspaceState.Query = value;
    }
    private bool _busy
    {
        get => WorkspaceState.Busy;
        set => WorkspaceState.Busy = value;
    }
    private string _thinkingLabel = "Думаю…";
    private List<WorkspaceChatMessage> _messages => WorkspaceState.Messages;
    private List<global::DriveeDataSpace.Core.Models.Report> _reports = new();
    private string _username = "";
    private string _displayName = "";
    private int _companyId = CompanyDefaults.DefaultCompanyId;
    private int? _userId;
    private bool _isAdmin;
    private bool _identityLoaded;
    private int? _openedReportId;
    private int _lastRenderedCount;

    private readonly string[] _templates =
    {
        "Количество заказов по дням за последние 30 дней",
        "Выручка по месяцам",
        "Распределение заказов по часам",
        "Доля отмен по дням за последний месяц",
        "Средний чек по статусам",
        "Сравни выручку за этот и прошлый месяц",
        "Среднее расстояние и длительность поездок"
    };

    private sealed class ChatMsg : global::DriveeDataSpace.Web.Models.WorkspaceChatMessage { }

    [SupplyParameterFromQuery(Name = "report")]
    public int? ReportId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        WorkspaceState.Changed += OnWorkspaceChanged;
        _thinkingLabel = WorkspaceState.ThinkingLabel;
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _username = authState.User.GetUsername();
        _displayName = authState.User.GetDisplayName();
        _companyId = authState.User.GetCompanyId();
        _userId = authState.User.GetUserId();
        _isAdmin = authState.User.IsAdmin();
        _identityLoaded = true;
        RefreshReports();
        TryOpenRequestedReport();
    }

    private void OnWorkspaceChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose() => WorkspaceState.Changed -= OnWorkspaceChanged;

    protected override void OnParametersSet()
    {
        if (_identityLoaded)
        {
            TryOpenRequestedReport();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_messages.Count != _lastRenderedCount || _busy)
        {
            _lastRenderedCount = _messages.Count;
            try { await JS.InvokeVoidAsync("driveeChat.scrollToBottom", "bi-chat-log"); } catch { }
        }
    }

    private void RefreshReports() =>
        _reports = string.IsNullOrWhiteSpace(_username)
            ? new List<global::DriveeDataSpace.Core.Models.Report>()
            : Reports.ListForAuthor(_companyId, _username);

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await Send();
        }
    }

    private async Task Send()
    {
        var q = _query?.Trim() ?? "";
        if (string.IsNullOrWhiteSpace(q) || _busy) return;
        _query = "";
        await RunQuery(q);
    }

    private async Task RunQuery(string q)
    {
        if (_busy) return;
        _messages.Add(new WorkspaceChatMessage { Role = "user", Text = q });
        _busy = true;
        _thinkingLabel = "Интерпретирую запрос…";
        WorkspaceState.ThinkingLabel = _thinkingLabel;
        WorkspaceState.NotifyChanged();

        try
        {
            var history = BuildHistory();
            var prevIntent = _messages
                .Where(m => m.Role == "result" && m.Result?.Intent?.Kind == "query")
                .Select(m => m.Result!.Intent)
                .LastOrDefault();

            var pr = await Engine.RunAsync(q, history, prevIntent, companyId: _companyId);
            pr.UserQuery = q;
            Audit.Record(_companyId, _userId, _username, "query.run", "query", success: string.IsNullOrWhiteSpace(pr.Error), details: q);

            var msg = new WorkspaceChatMessage();
            if (pr.IsChat)
            {
                msg.Role = "chat";
                msg.Text = pr.ChatReply;
            }
            else
            {
                msg.Role = "result";
                msg.Result = pr;
                msg.Visualization = pr.Visualization;
                msg.ReportName = BuildReportName(pr);
            }
            _messages.Add(msg);
        }
        catch (Exception exception)
        {
            _messages.Add(new WorkspaceChatMessage
            {
                Role = "chat",
                Text = $"Не удалось выполнить запрос: {exception.Message}"
            });
        }
        finally
        {
            _busy = false;
            WorkspaceState.ThinkingLabel = "\u0414\u0443\u043c\u0430\u044e\u2026";
            _thinkingLabel = WorkspaceState.ThinkingLabel;
            WorkspaceState.NotifyChanged();
        }
    }

    private void UseTemplate(string t) => _query = t;

    private List<ChatTurn> BuildHistory()
    {
        var turns = new List<ChatTurn>();
        foreach (var m in _messages.TakeLast(8))
        {
            if (m.Role == "user" && !string.IsNullOrWhiteSpace(m.Text))
                turns.Add(new ChatTurn("user", m.Text));
            else if (m.Role == "chat" && !string.IsNullOrWhiteSpace(m.Text))
                turns.Add(new ChatTurn("assistant", m.Text));
            else if (m.Role == "result" && m.Result?.Intent != null)
                turns.Add(new ChatTurn("assistant", JsonSerializer.Serialize(m.Result.Intent)));
        }
        // Drop the final "user" turn since RunQuery will add it as the user message
        if (turns.Count > 0 && turns[^1].Role == "user") turns.RemoveAt(turns.Count - 1);
        return turns;
    }

    private void ClearChat() => WorkspaceState.ClearChat();

    private void SwitchViz(WorkspaceChatMessage m, string v) => m.Visualization = v;

    private void SaveReport(WorkspaceChatMessage m)
    {
        if (m.Result?.Intent == null || m.Result.Sql == null) return;
        var r = new Report
        {
            Name = string.IsNullOrWhiteSpace(m.ReportName) ? BuildReportName(m.Result) : m.ReportName.Trim(),
            CompanyId = _companyId,
            UserQuery = m.Result.UserQuery,
            IntentJson = JsonSerializer.Serialize(m.Result.Intent),
            Sql = m.Result.Sql,
            Visualization = m.Visualization,
            Author = _username
        };
        var id = Reports.Save(r);
        Audit.Record(_companyId, _userId, _username, "report.save", "report", id.ToString(), success: true);
        m.SavedAs = $"#{id}";
        RefreshReports();
    }

    private void OpenReport(int id)
    {
        var r = Reports.GetForAuthor(_companyId, id, _username, _isAdmin);
        if (r == null) return;
        _messages.Add(new ChatMsg { Role = "user", Text = $"[↻ отчёт] {r.UserQuery}" });
        try
        {
            var pr = Engine.ReplayFromReport(r.IntentJson, companyId: _companyId);
            pr.UserQuery = r.UserQuery;
            Audit.Record(_companyId, _userId, _username, "report.rerun", "report", id.ToString(), success: true);
            _messages.Add(new ChatMsg
            {
                Role = "result",
                Result = pr,
                Visualization = pr.Visualization,
                ReportName = r.Name,
                SavedAs = $"#{r.Id}"
            });
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMsg { Role = "chat", Text = "Не удалось переисполнить отчёт: " + ex.Message });
        }
    }

    private void DeleteReport(int id)
    {
        Reports.DeleteForAuthor(_companyId, id, _username, _isAdmin);
        Audit.Record(_companyId, _userId, _username, "report.delete", "report", id.ToString(), success: true);
        RefreshReports();
    }

    private void TryOpenRequestedReport()
    {
        if (ReportId is not int requestedId || requestedId <= 0 || requestedId == _openedReportId)
        {
            return;
        }

        _openedReportId = requestedId;
        OpenReport(requestedId);
    }

    private void ToggleInsightTab(WorkspaceChatMessage m, string tab) =>
        m.InsightTab = string.Equals(m.InsightTab, tab, StringComparison.Ordinal) ? null : tab;

    private static string GetInsightTabClass(WorkspaceChatMessage m, string tab) =>
        string.Equals(m.InsightTab, tab, StringComparison.Ordinal) ? "bi-insight-tab active" : "bi-insight-tab";

    private static string SuggestName(PipelineResult pr)
    {
        if (pr.Intent == null) return pr.UserQuery;
        var parts = new List<string> { pr.Intent.Metric ?? "report" };
        if (!string.IsNullOrEmpty(pr.Intent.GroupBy)) parts.Add($"× {pr.Intent.GroupBy}");
        if (!string.IsNullOrEmpty(pr.Intent.Period))
            parts.Add(PeriodResolver.Resolve(pr.Intent.Period)?.Label ?? pr.Intent.Period!);
        return string.Join(" ", parts);
    }

    private static string SerializeIntent(QueryIntent? i) =>
        i == null ? "" : JsonSerializer.Serialize(i, new JsonSerializerOptions { WriteIndented = true });

    private static string BuildReportName(PipelineResult pr)
    {
        if (pr.Intent == null)
        {
            return pr.UserQuery;
        }

        var parts = new List<string> { pr.Intent.Metric ?? "report" };
        var groupBy = pr.Intent.GroupBy ?? pr.Intent.Dimensions.FirstOrDefault();
        if (!string.IsNullOrWhiteSpace(groupBy))
        {
            parts.Add($"x {groupBy}");
        }

        var periodLabel = pr.StructuredExplain?.PeriodLabel
            ?? pr.Intent.DateRange?.Label
            ?? pr.Intent.Period;
        if (!string.IsNullOrWhiteSpace(periodLabel))
        {
            parts.Add(periodLabel);
        }

        return string.Join(" ", parts);
    }

    private static string FormatCell(object? v) => v switch
    {
        null => "—",
        double d => d.ToString("0.##"),
        float f => f.ToString("0.##"),
        decimal m => m.ToString("0.##"),
        _ => v.ToString() ?? ""
    };

    private RenderFragment RenderResult(WorkspaceChatMessage m) => builder =>
    {
        var pr = m.Result!;
        var seq = 0;
        var hasReasoning = pr.ReasoningTrail.Count > 0;
        var hasSql = !string.IsNullOrWhiteSpace(pr.Sql);

        if (pr.Error != null)
        {
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "bi-error");
            builder.AddContent(seq++, $"Ошибка: {pr.Error}");
            builder.CloseElement();
            return;
        }

        // Explain card
        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "bi-result-card");
        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "bi-result-explain");
        builder.AddContent(seq++, pr.Explain);
        builder.CloseElement();

        if (pr.Intent?.Explanation is { Length: > 0 } llmNote && string.Equals(m.InsightTab, ReasoningTab, StringComparison.Ordinal))
        {
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "bi-explain-llm");
            builder.AddContent(seq++, llmNote);
            builder.CloseElement();
        }

        foreach (var w in pr.Warnings)
        {
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "bi-warn");
            builder.AddContent(seq++, w);
            builder.CloseElement();
        }

        // Meta row: confidence + row stats
        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "bi-result-meta");
        var confClass = pr.Confidence >= 0.7 ? "high" : pr.Confidence >= 0.4 ? "mid" : "low";
        builder.OpenElement(seq++, "span");
        builder.AddAttribute(seq++, "class", $"bi-confidence {confClass}");
        builder.AddContent(seq++, $"confidence {(int)(pr.Confidence * 100)}%");
        builder.CloseElement();

        if (pr.Result != null)
        {
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "bi-meta-info");
            builder.AddContent(seq++, $"{pr.Result.RowCount} строк · {pr.Result.DurationMs} мс");
            builder.CloseElement();
        }
        builder.CloseElement(); // meta

        if (hasReasoning || hasSql)
        {
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "bi-insight-tabs");

            if (hasReasoning)
            {
                builder.OpenElement(seq++, "button");
                builder.AddAttribute(seq++, "type", "button");
                builder.AddAttribute(seq++, "class", GetInsightTabClass(m, ReasoningTab));
                builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => ToggleInsightTab(m, ReasoningTab)));
                builder.AddContent(seq++, "\u041a\u0430\u043a \u044f \u043f\u043e\u043d\u044f\u043b \u0437\u0430\u043f\u0440\u043e\u0441");
                builder.CloseElement();
            }

            if (hasSql)
            {
                builder.OpenElement(seq++, "button");
                builder.AddAttribute(seq++, "type", "button");
                builder.AddAttribute(seq++, "class", GetInsightTabClass(m, SqlTab));
                builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => ToggleInsightTab(m, SqlTab)));
                builder.AddContent(seq++, "SQL \u0437\u0430\u043f\u0440\u043e\u0441");
                builder.CloseElement();
            }

            builder.CloseElement();
        }

        // Reasoning trail — always visible
        if (hasReasoning && string.Equals(m.InsightTab, ReasoningTab, StringComparison.Ordinal))
        {
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "bi-trail");

            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "bi-trail-title");
            builder.AddContent(seq++, "\u041a\u0430\u043a \u044f \u043f\u043e\u043d\u044f\u043b(\u0430) \u0437\u0430\u043f\u0440\u043e\u0441");
            builder.CloseElement();

            builder.OpenElement(seq++, "ol");
            builder.AddAttribute(seq++, "class", "bi-trail-list");
            foreach (var step in pr.ReasoningTrail)
            {
                if (!string.IsNullOrEmpty(step.Code))
                {
                    continue;
                }

                builder.OpenElement(seq++, "li");
                builder.AddAttribute(seq++, "class", "bi-trail-step");

                builder.OpenElement(seq++, "div");
                builder.AddAttribute(seq++, "class", "bi-trail-head");
                builder.OpenElement(seq++, "span");
                builder.AddAttribute(seq++, "class", "bi-trail-ico");
                builder.AddContent(seq++, step.Icon);
                builder.CloseElement();
                builder.OpenElement(seq++, "span");
                builder.AddAttribute(seq++, "class", "bi-trail-step-title");
                builder.AddContent(seq++, step.Title);
                builder.CloseElement();
                builder.CloseElement();

                builder.OpenElement(seq++, "div");
                builder.AddAttribute(seq++, "class", "bi-trail-detail");
                foreach (var line in (step.Detail ?? "").Split('\n'))
                {
                    builder.OpenElement(seq++, "div");
                    builder.AddContent(seq++, line);
                    builder.CloseElement();
                }
                builder.CloseElement();

                builder.CloseElement(); // li
            }
            builder.CloseElement(); // ol
            builder.CloseElement(); // bi-trail
        }

        // Secondary details (intent JSON, tech) — still behind toggle for devs
        if (hasSql && string.Equals(m.InsightTab, SqlTab, StringComparison.Ordinal))
        {
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "bi-insight-panel");

            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "bi-trail-title");
            builder.AddContent(seq++, "SQL \u0437\u0430\u043f\u0440\u043e\u0441");
            builder.CloseElement();

            builder.OpenElement(seq++, "pre");
            builder.AddAttribute(seq++, "class", "bi-sql");
            builder.AddContent(seq++, pr.Sql);
            builder.CloseElement();

            builder.OpenElement(seq++, "button");
            builder.AddAttribute(seq++, "class", "bi-details-btn");
            builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => m.DetailsOpen = !m.DetailsOpen));
            builder.AddContent(seq++, m.DetailsOpen
                ? "\u0421\u043a\u0440\u044b\u0442\u044c \u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u0434\u0435\u0442\u0430\u043b\u0438"
                : "\u041f\u043e\u043a\u0430\u0437\u0430\u0442\u044c \u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u0434\u0435\u0442\u0430\u043b\u0438");
            builder.CloseElement();

            if (m.DetailsOpen)
            {
                builder.OpenElement(seq++, "div");
                builder.AddAttribute(seq++, "class", "bi-tech");
                builder.AddContent(seq++, pr.TechnicalExplain);
                builder.CloseElement();

                builder.OpenElement(seq++, "pre");
                builder.AddAttribute(seq++, "class", "bi-json");
                builder.AddContent(seq++, SerializeIntent(pr.Intent));
                builder.CloseElement();
            }

            builder.CloseElement();
        }

        /*
        if (false)
        {
        builder.OpenElement(seq++, "button");
        builder.AddAttribute(seq++, "class", "bi-details-btn");
        builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => m.DetailsOpen = !m.DetailsOpen));
        builder.AddContent(seq++, m.DetailsOpen ? "Скрыть технические детали" : "Показать технические детали");
        builder.CloseElement();

        if (m.DetailsOpen)
        {
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "bi-tech");
            builder.AddContent(seq++, pr.TechnicalExplain);
            builder.CloseElement();

            builder.OpenElement(seq++, "pre");
            builder.AddAttribute(seq++, "class", "bi-json");
            builder.AddContent(seq++, SerializeIntent(pr.Intent));
            builder.CloseElement();
        }
        }
        */
        builder.CloseElement(); // explain card

        if (pr.Result != null && pr.Result.RowCount > 0)
        {
            // Viz card
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "bi-result-card");

            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "bi-viz-switch");
            foreach (var v in new[] { "bar", "line", "pie", "table" })
            {
                var vv = v;
                builder.OpenElement(seq++, "button");
                builder.AddAttribute(seq++, "class", vv == m.Visualization ? "active" : "");
                builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => SwitchViz(m, vv)));
                builder.AddContent(seq++, vv);
                builder.CloseElement();
            }
            builder.CloseElement();

            if (m.Visualization != "table")
            {
                builder.OpenComponent<ResultChart>(seq++);
                builder.AddAttribute(seq++, "Result", pr.Result);
                builder.AddAttribute(seq++, "Type", m.Visualization);
                builder.AddAttribute(seq++, "Title", pr.Explain ?? "");
                builder.SetKey(m.Id + ":" + m.Visualization);
                builder.CloseComponent();
            }
            else
            {
                builder.AddContent(seq++, RenderTable(pr.Result));
            }
            builder.CloseElement();

            // Save row
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "bi-save-row");
            if (m.SavedAs == null)
            {
                builder.OpenElement(seq++, "input");
                builder.AddAttribute(seq++, "class", "bi-save-name");
                builder.AddAttribute(seq++, "placeholder", "Название отчёта");
                builder.AddAttribute(seq++, "value", m.ReportName);
                builder.AddAttribute(seq++, "oninput",
                    EventCallback.Factory.Create<ChangeEventArgs>(this, e => m.ReportName = e.Value?.ToString() ?? ""));
                builder.CloseElement();

                builder.OpenElement(seq++, "button");
                builder.AddAttribute(seq++, "class", "bi-save-btn");
                builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => SaveReport(m)));
                builder.AddContent(seq++, "Сохранить отчёт");
                builder.CloseElement();
            }
            else
            {
                builder.OpenElement(seq++, "span");
                builder.AddAttribute(seq++, "class", "bi-save-msg");
                builder.AddContent(seq++, $"Сохранено как {m.SavedAs}");
                builder.CloseElement();
            }
            builder.CloseElement();
        }
    };

    private RenderFragment RenderTable(QueryResult qr) => builder =>
    {
        var seq = 0;
        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "bi-table-wrap");
        builder.OpenElement(seq++, "table");
        builder.AddAttribute(seq++, "class", "bi-table");
        builder.OpenElement(seq++, "thead");
        builder.OpenElement(seq++, "tr");
        foreach (var c in qr.Columns)
        {
            builder.OpenElement(seq++, "th");
            builder.AddContent(seq++, c);
            builder.CloseElement();
        }
        builder.CloseElement();
        builder.CloseElement();
        builder.OpenElement(seq++, "tbody");
        foreach (var row in qr.Rows.Take(200))
        {
            builder.OpenElement(seq++, "tr");
            foreach (var cell in row)
            {
                builder.OpenElement(seq++, "td");
                builder.AddContent(seq++, FormatCell(cell));
                builder.CloseElement();
            }
            builder.CloseElement();
        }
        builder.CloseElement();
        builder.CloseElement();
        if (qr.RowCount > 200)
        {
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "bi-muted");
            builder.AddContent(seq++, $"Показаны первые 200 из {qr.RowCount}");
            builder.CloseElement();
        }
        builder.CloseElement();
    };
}

@page "/admin/data-sources"
@attribute [Authorize(Roles = AppRoles.AdminAccess)]
@rendermode InteractiveServer
@inject DataSourceService DataSources
@inject LlmSettingsService LlmSettingsService
@inject AnalyticsRegressionService AnalyticsRegression
@inject AuditLogService Audit
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Drivee BI · Data sources</PageTitle>

<div class="bi-workspace">
    <aside class="bi-sidebar">
        <div class="bi-brand">
            <div class="bi-logo">◆</div>
            <div>
                <div class="bi-brand-title">Drivee BI</div>
                <div class="bi-brand-sub">NL → SQL аналитика</div>
            </div>
        </div>

        <div class="bi-user-card">
            <div class="bi-user-label">Сеанс</div>
            <div class="bi-user-name">@_displayName</div>
            <div class="bi-user-meta">@_username · Администратор</div>
            <form method="post" action="/auth/logout">
                <button type="submit" class="bi-logout-btn">Выйти</button>
            </form>
        </div>

        <SidebarNav Current="data-sources" IsAdmin="true" />
    </aside>

    <main class="bi-chat-main">
        <header class="bi-chat-header">
            <div>
                <h1>Источники данных компании</h1>
                <div class="bi-tagline">Администратор подключает БД, проверяет схему и публикует semantic layer. Аналитики работают только с активным, утверждённым источником.</div>
            </div>
        </header>

        <div class="bi-reports-body">
            @if (!string.IsNullOrWhiteSpace(_notice))
            {
                <div class="admin-notice">@_notice</div>
            }

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="admin-error">@_error</div>
            }

            <div class="datasource-layout">
                <section class="admin-section llm-settings-section">
                    <div class="admin-section-head">
                        <div>
                            <h2>LLM provider</h2>
                            <div class="bi-tagline">Администратор выбирает, куда отправлять NL-запросы: в локальный сервер или в GigaChat. Секретный ключ здесь не показывается и не хранится в UI.</div>
                        </div>
                    </div>

                    <div class="bi-card llm-settings-card">
                        <div class="llm-provider-row">
                            <label class="llm-provider-field">
                                Провайдер
                                <select class="auth-input" @bind="_selectedLlmProvider" disabled="@_busy">
                                    @foreach (var provider in LlmProviders.All)
                                    {
                                        <option value="@provider">@provider</option>
                                    }
                                </select>
                            </label>
                            <label class="llm-provider-field llm-key-field">
                                GigaChat AuthorizationKey
                                <input class="auth-input"
                                       type="password"
                                       autocomplete="off"
                                       placeholder="@(_llmSettings?.IsGigaChatConfigured == true ? "Новый ключ, если нужно заменить" : "Введите ключ")"
                                       @bind="_gigaChatAuthorizationKey"
                                       @bind:event="oninput"
                                       disabled="@_busy" />
                                <span class="llm-key-hint">Существующий ключ не показывается. При сохранении он шифруется в metadata DB.</span>
                            </label>
                            <button type="button" class="bi-btn" @onclick="SaveLlmProvider" disabled="@_busy">Сохранить</button>
                        </div>

                        @if (_llmSettings != null)
                        {
                            <div class="llm-facts">
                                <div class="llm-fact">
                                    <div class="llm-fact-label">Сейчас выбран</div>
                                    <div class="llm-fact-value">@_llmSettings.Provider</div>
                                </div>
                                <div class="llm-fact">
                                    <div class="llm-fact-label">Локальный сервер</div>
                                    <div class="llm-fact-value">@_llmSettings.LocalModel</div>
                                    <div class="llm-fact-sub">@_llmSettings.LocalEndpoint</div>
                                </div>
                                <div class="llm-fact">
                                    <div class="llm-fact-label">GigaChat</div>
                                    <div class="llm-fact-value">@_llmSettings.GigaChatModel</div>
                                    <div class="@(_llmSettings.IsGigaChatConfigured ? "llm-secret-ok" : "llm-secret-missing")">
                                        @(_llmSettings.IsGigaChatConfigured ? "ключ настроен" : "ключ не настроен")
                                    </div>
                                </div>
                            </div>

                            @if (string.Equals(_selectedLlmProvider, LlmProviders.GigaChat, StringComparison.OrdinalIgnoreCase) && !_llmSettings.IsGigaChatConfigured)
                            {
                                <div class="admin-error compact">Перед выбором GigaChat введите AuthorizationKey или добавьте его через dotnet user-secrets / production secret storage.</div>
                            }
                        }
                    </div>

                    <div class="bi-card analytics-checks">
                        <div class="analytics-checks-head">
                            <div>
                                <div class="analytics-checks-title">NL→SQL regression</div>
                                <div class="analytics-checks-sub">Проверка типовых запросов: выручка за этот и прошлый месяц, доля отмен за 30 дней, топ городов по отменам.</div>
                            </div>
                            <button type="button" class="bi-btn ghost" @onclick="RunRegressionChecks" disabled="@(_busy || _regressionRunning)">
                                @(_regressionRunning ? "Проверяю…" : "Запустить проверку")
                            </button>
                        </div>

                        @if (_regressionResult != null)
                        {
                            <div class="@(_regressionResult.Passed ? "analytics-checks-status ok" : "analytics-checks-status bad")">
                                @(_regressionResult.Passed
                                    ? $"Все проверки прошли: {_regressionResult.PassedCount}/{_regressionResult.Cases.Count}."
                                    : $"Есть ошибки: {_regressionResult.PassedCount}/{_regressionResult.Cases.Count} прошли.")
                            </div>

                            <div class="analytics-checks-list">
                                @foreach (var item in _regressionResult.Cases)
                                {
                                    <div class="analytics-check-item @(item.Passed ? "ok" : "bad")">
                                        <div class="analytics-check-main">
                                            <div class="analytics-check-query">@item.Query</div>
                                            <div class="analytics-check-meta">
                                                metric: @(item.Metric ?? "—") · group: @(item.Dimensions.Count == 0 ? "—" : string.Join(", ", item.Dimensions)) · period: @(item.Period ?? "—")
                                            </div>
                                        </div>
                                        <span class="analytics-check-badge">@(item.Passed ? "ok" : "fail")</span>
                                        @if (item.Errors.Count > 0)
                                        {
                                            <div class="analytics-check-errors">@string.Join("; ", item.Errors)</div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </section>

                <section class="admin-section">
                    <div class="admin-section-head">
                        <div>
                            <h2>Подключения</h2>
                            <div class="bi-tagline">Активным может быть только один источник. Встроенный Drivee остаётся fallback-демо.</div>
                        </div>
                        <div class="datasource-head-actions">
                            <button type="button" class="bi-btn ghost" @onclick="RotateConnectionSecrets" disabled="@_busy">Ротация encryption</button>
                            <button type="button" class="bi-btn" @onclick="NewSource">Новый источник</button>
                        </div>
                    </div>

                    <div class="bi-card bi-card-table">
                        <table class="bi-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Источник</th>
                                    <th>Provider</th>
                                    <th>Статус</th>
                                    <th>Проверка</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _items)
                                {
                                    <tr class="@(item.Id == _input.Id ? "datasource-selected" : "")">
                                        <td>@item.Id</td>
                                        <td>
                                            <div class="admin-user-name">@item.Name</div>
                                            <div class="admin-user-sub">@(item.IsBuiltin ? "встроенный demo source" : "company source")</div>
                                        </td>
                                        <td>@item.Provider</td>
                                        <td>
                                            <span class="datasource-status @DataSourceStatusClass(item)">@DataSourceStatusLabel(item)</span>
                                        </td>
                                        <td>
                                            <div class="datasource-validation">
                                                <span class="datasource-status @(item.IsVerified ? "verified" : "draft")">
                                                    @(item.IsVerified ? "проверен" : "не проверен")
                                                </span>
                                                <div class="admin-user-sub">@FormatValidationDate(item.LastValidatedAt)</div>
                                                @if (!string.IsNullOrWhiteSpace(item.LastValidationError))
                                                {
                                                    <div class="datasource-error-text">@item.LastValidationError</div>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <button type="button" class="bi-btn ghost" @onclick="() => Edit(item)">Открыть</button>
                                            @if (!item.IsActive)
                                            {
                                                <button type="button"
                                                        class="bi-btn"
                                                        title="@ActivateTitle(item)"
                                                        disabled="@(_busy || !CanActivate(item))"
                                                        @onclick="() => Activate(item.Id)">
                                                    Активировать
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>

                <section class="admin-section">
                    <div class="admin-section-head">
                        <div>
                            <h2>@(_input.Id.HasValue ? "Настройка источника" : "Новый источник")</h2>
                            <div class="bi-tagline">LLM видит только semantic layer, а SQL строится кодом из подтверждённых метрик и полей.</div>
                        </div>
                    </div>

                    <div class="bi-card datasource-form" @key="_formKey">
                        <div class="datasource-wizard">
                            @foreach (var step in BuildWizardSteps())
                            {
                                <div class="datasource-wizard-step @(step.Done ? "done" : step.Current ? "current" : "")">
                                    <span>@step.Number</span>
                                    <div>
                                        <strong>@step.Title</strong>
                                        <small>@step.Subtitle</small>
                                    </div>
                                </div>
                            }
                        </div>

                        @if (_selectedIsBuiltin)
                        {
                            <div class="datasource-readonly-note">
                                Это встроенный demo-источник. Его можно проверить и проанализировать, но редактирование отключено. Для настройки своей БД создайте новый источник или копию demo-source.
                            </div>
                        }

                        <label>
                            Название
                            <input class="auth-input" @bind="_input.Name" @bind:event="oninput" disabled="@_selectedIsBuiltin" />
                        </label>

                        <label>
                            Provider
                            <select class="auth-input" @bind="_input.Provider" disabled="@_selectedIsBuiltin">
                                @foreach (var provider in DataSourceProviders.All)
                                {
                                    <option value="@provider">@provider</option>
                                }
                            </select>
                        </label>

                        <label>
                            Строка подключения
                            <textarea class="auth-input auth-textarea datasource-connection" @bind="_input.ConnectionString" @bind:event="oninput" disabled="@_selectedIsBuiltin"></textarea>
                        </label>

                        @if (_input.Id.HasValue)
                        {
                            <div class="datasource-status-panel">
                                <div>
                                    <div class="llm-fact-label">Текущий статус</div>
                                    <div class="llm-fact-value">@DataSourceStatusLabel(_selectedSource)</div>
                                </div>
                                <div>
                                    <div class="llm-fact-label">Последняя проверка</div>
                                    <div class="llm-fact-value">@FormatValidationDate(_selectedSource?.LastValidatedAt)</div>
                                </div>
                                <div>
                                    <div class="llm-fact-label">Последняя ошибка</div>
                                    <div class="llm-fact-sub">@DisplayText(_selectedSource?.LastValidationError)</div>
                                </div>
                            </div>
                        }

                        <label class="datasource-check">
                            <input type="checkbox" @bind="_input.MakeActive" disabled="@_selectedIsBuiltin" />
                            Сделать активным после сохранения
                        </label>

                        <label>
                            Semantic layer JSON
                            <textarea class="auth-input datasource-semantic" @bind="_input.SemanticJson" @bind:event="oninput" disabled="@_selectedIsBuiltin"></textarea>
                        </label>

                        <div class="datasource-actions">
                            @if (_selectedIsBuiltin)
                            {
                                <button type="button" class="bi-btn" @onclick="CloneSelectedAsNew" disabled="@_busy">Создать копию для редактирования</button>
                            }
                            else
                            {
                                <button type="button" class="bi-btn" @onclick="Save" disabled="@_busy">Сохранить</button>
                            }
                            <button type="button" class="bi-btn ghost" @onclick="TestSelected" disabled="@(_busy || !_input.Id.HasValue)">Проверить</button>
                            <button type="button" class="bi-btn ghost" @onclick="InspectSelected" disabled="@(_busy || !_input.Id.HasValue)">Анализ схемы</button>
                            <button type="button" class="bi-btn ghost" @onclick="GenerateDraft" disabled="@(_busy || !_input.Id.HasValue)">Сгенерировать draft semantic</button>
                            @if (_input.Id.HasValue && !_selectedIsActive)
                            {
                                <button type="button"
                                        class="bi-btn"
                                        disabled="@(_busy || !CanActivate(_selectedSource))"
                                        title="@ActivateTitle(_selectedSource)"
                                        @onclick="() => Activate(_input.Id.Value)">
                                    Активировать
                                </button>
                            }
                            @if (_input.Id.HasValue && !_selectedIsBuiltin && !_selectedIsActive)
                            {
                                <button type="button" class="bi-btn danger" @onclick="DeleteSelected" disabled="@_busy">Удалить</button>
                            }
                        </div>

                        @if (_testResult != null)
                        {
                            <div class="@(_testResult.Ok ? "admin-notice compact" : "admin-error compact")">@_testResult.Message</div>
                        }
                    </div>

                    @if (_schema != null)
                    {
                        <div class="bi-card bi-card-table datasource-schema">
                            <table class="bi-table">
                                <thead>
                                    <tr>
                                        <th>Таблица</th>
                                        <th>Строк</th>
                                        <th>Колонки</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var table in _schema.Tables)
                                    {
                                        <tr>
                                            <td>@FormatTableName(table)</td>
                                            <td>@(table.EstimatedRows?.ToString() ?? "—")</td>
                                            <td>@string.Join(", ", table.Columns.Select(column => $"{column.Name}:{column.DataType}"))</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </section>
            </div>
        </div>
    </main>
</div>

@code {
    private List<CompanyDataSource> _items = new();
    private DataSourceInput _input = new();
    private DataSourceTestResult? _testResult;
    private SchemaInspectionResult? _schema;
    private string _username = "";
    private string _displayName = "";
    private int _companyId = CompanyDefaults.DefaultCompanyId;
    private int _adminUserId;
    private bool _busy;
    private bool _selectedIsBuiltin;
    private bool _selectedIsActive;
    private CompanyDataSource? _selectedSource;
    private string _formKey = Guid.NewGuid().ToString("N");
    private string? _notice;
    private string? _error;
    private LlmSettings? _llmSettings;
    private string _selectedLlmProvider = LlmProviders.Local;
    private string _gigaChatAuthorizationKey = "";
    private bool _regressionRunning;
    private AnalyticsRegressionRunResult? _regressionResult;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _username = authState.User.GetUsername();
        _displayName = authState.User.GetDisplayName();
        _companyId = authState.User.GetCompanyId();
        _adminUserId = authState.User.GetUserId() ?? 0;
        LoadLlmSettings();
        Refresh();
        Edit(_items.FirstOrDefault(item => item.IsActive) ?? _items.FirstOrDefault());
    }

    private void Refresh() => _items = DataSources.List(_companyId);

    private void LoadLlmSettings()
    {
        _llmSettings = LlmSettingsService.Get(_companyId);
        _selectedLlmProvider = _llmSettings.Provider;
    }

    private void SaveLlmProvider()
    {
        RunAdminAction(() =>
        {
            _llmSettings = LlmSettingsService.Save(
                new UpdateLlmSettingsRequest(_selectedLlmProvider, _gigaChatAuthorizationKey),
                _companyId);
            _selectedLlmProvider = _llmSettings.Provider;
            _gigaChatAuthorizationKey = "";
            AuditAdmin("llm_settings.update", "llm_settings", details: _llmSettings.Provider);
            _notice = $"LLM provider сохранён: {_llmSettings.Provider}.";
        });
    }

    private async Task RunRegressionChecks()
    {
        if (_busy || _regressionRunning)
            return;

        _busy = true;
        _regressionRunning = true;
        _notice = null;
        _error = null;
        try
        {
            _regressionResult = await AnalyticsRegression.RunAsync(_companyId);
            AuditAdmin(
                "analytics_regression.run",
                "analytics_regression",
                success: _regressionResult.Passed,
                details: $"{_regressionResult.PassedCount}/{_regressionResult.Cases.Count}");
            _notice = _regressionResult.Passed
                ? "NL→SQL проверки прошли."
                : "NL→SQL проверки нашли ошибки интерпретации.";
        }
        catch (Exception exception) when (exception is InvalidOperationException or HttpRequestException or TaskCanceledException)
        {
            _error = exception.Message;
            AuditAdmin("analytics_regression.run", "analytics_regression", success: false, details: exception.Message);
        }
        finally
        {
            _regressionRunning = false;
            _busy = false;
        }
    }

    private void NewSource()
    {
        _input = new DataSourceInput { Provider = DataSourceProviders.Sqlite };
        _selectedIsBuiltin = false;
        _selectedIsActive = false;
        _selectedSource = null;
        _testResult = null;
        _schema = null;
        _notice = null;
        _error = null;
        ResetFormKey();
    }

    private void Edit(CompanyDataSource? source)
    {
        if (source == null)
        {
            NewSource();
            return;
        }

        _input = new DataSourceInput
        {
            Id = source.Id,
            Name = source.Name,
            Provider = source.Provider,
            ConnectionString = source.ConnectionString,
            SemanticJson = source.SemanticJson ?? "",
            MakeActive = source.IsActive
        };
        _selectedIsBuiltin = source.IsBuiltin;
        _selectedIsActive = source.IsActive;
        _selectedSource = source;
        _testResult = null;
        _schema = string.IsNullOrWhiteSpace(source.SchemaJson)
            ? null
            : System.Text.Json.JsonSerializer.Deserialize<SchemaInspectionResult>(source.SchemaJson, new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web));
        _notice = null;
        _error = null;
        ResetFormKey();
    }

    private void CloneSelectedAsNew()
    {
        var sourceName = string.IsNullOrWhiteSpace(_input.Name)
            ? "Company data source"
            : $"{_input.Name} custom";

        _input = new DataSourceInput
        {
            Name = sourceName,
            Provider = _input.Provider,
            ConnectionString = _input.ConnectionString,
            SemanticJson = _input.SemanticJson,
            MakeActive = false
        };
        _selectedIsBuiltin = false;
        _selectedIsActive = false;
        _selectedSource = null;
        _testResult = null;
        _notice = "Создана редактируемая копия. Проверьте строку подключения и semantic layer, затем сохраните источник.";
        _error = null;
        ResetFormKey();
    }

    private void Save()
    {
        RunAdminAction(() =>
        {
            var id = DataSources.Save(_input, _companyId);
            Refresh();
            Edit(_items.First(item => item.Id == id));
            AuditAdmin("data_source.save", "data_source", id.ToString());
            _notice = "Источник данных сохранён.";
        });
    }

    private void Activate(int id)
    {
        RunAdminAction(() =>
        {
            DataSources.Activate(id, _companyId);
            Refresh();
            Edit(_items.First(item => item.Id == id));
            AuditAdmin("data_source.activate", "data_source", id.ToString());
            _notice = "Источник данных активирован.";
        });
    }

    private void DeleteSelected()
    {
        if (_input.Id is not int id)
            return;

        RunAdminAction(() =>
        {
            DataSources.Delete(id, _companyId);
            Refresh();
            Edit(_items.FirstOrDefault(item => item.IsActive) ?? _items.FirstOrDefault());
            AuditAdmin("data_source.delete", "data_source", id.ToString());
            _notice = "Источник данных удалён.";
        });
    }

    private void TestSelected()
    {
        if (_input.Id is not int id)
            return;

        RunAdminAction(() =>
        {
            var result = DataSources.Test(id, _companyId);
            Refresh();
            Edit(_items.First(item => item.Id == id));
            _testResult = result;
            AuditAdmin("data_source.test", "data_source", id.ToString(), _testResult.Ok, _testResult.Message);
        });
    }

    private void InspectSelected()
    {
        if (_input.Id is not int id)
            return;

        RunAdminAction(() =>
        {
            _schema = DataSources.InspectSchema(id, _companyId);
            Refresh();
            if (_items.FirstOrDefault(item => item.Id == id) is { } refreshed)
                _selectedSource = refreshed;
            AuditAdmin("data_source.inspect_schema", "data_source", id.ToString(), details: $"{_schema.Tables.Count} tables");
            _notice = $"Схема прочитана: {_schema.Tables.Count} таблиц.";
        });
    }

    private void GenerateDraft()
    {
        if (_input.Id is not int id)
            return;

        RunAdminAction(() =>
        {
            var semanticDraft = DataSources.BuildSemanticDraftFromLastSchema(id, _companyId);
            AuditAdmin("data_source.semantic_draft", "data_source", id.ToString());

            if (_selectedIsBuiltin)
            {
                var sourceName = string.IsNullOrWhiteSpace(_input.Name)
                    ? "Company data source"
                    : $"{_input.Name} custom";

                _input = new DataSourceInput
                {
                    Name = sourceName,
                    Provider = _input.Provider,
                    ConnectionString = _input.ConnectionString,
                    SemanticJson = semanticDraft,
                    MakeActive = false
                };
                _selectedIsBuiltin = false;
                _selectedIsActive = false;
                _testResult = null;
                _notice = "Draft semantic layer создан в новой редактируемой копии demo-source. Проверьте бизнес-смысл и сохраните источник.";
            }
            else
            {
                _input.SemanticJson = semanticDraft;
                _notice = "Draft semantic layer создан. Проверьте бизнес-смысл перед сохранением и активацией.";
            }

            ResetFormKey();
        });
    }

    private void RotateConnectionSecrets()
    {
        RunAdminAction(() =>
        {
            var result = DataSources.RotateConnectionSecrets(_companyId);
            AuditAdmin("data_source.secret.rotate", "data_source", details: $"{result.RotatedCount} rotated, {result.SkippedCount} skipped");
            _notice = $"Connection string secrets перешифрованы: {result.RotatedCount}; пропущено: {result.SkippedCount}.";
            Refresh();
            if (_input.Id is int id && _items.FirstOrDefault(item => item.Id == id) is { } selected)
                Edit(selected);
        });
    }

    private void ResetFormKey() => _formKey = Guid.NewGuid().ToString("N");

    private static string FormatTableName(SchemaTableInfo table) =>
        string.IsNullOrWhiteSpace(table.SchemaName)
            ? table.Name
            : $"{table.SchemaName}.{table.Name}";

    private IReadOnlyList<WizardStep> BuildWizardSteps()
    {
        var hasConnection = !string.IsNullOrWhiteSpace(_input.ConnectionString);
        var isSaved = _input.Id.HasValue;
        var isVerified = _selectedSource?.IsVerified == true;
        var hasSchema = _schema != null || !string.IsNullOrWhiteSpace(_selectedSource?.SchemaJson);
        var hasSemantic = _selectedIsBuiltin || !string.IsNullOrWhiteSpace(_input.SemanticJson);
        var isActive = _selectedIsActive;
        var current = !hasConnection ? 2 : !isSaved || !isVerified ? 3 : !hasSchema ? 4 : !hasSemantic ? 5 : !isActive ? 6 : 6;

        return new[]
        {
            new WizardStep(1, "Provider", "выбран тип БД", !string.IsNullOrWhiteSpace(_input.Provider), current == 1),
            new WizardStep(2, "Connection string", "сохраните подключение", hasConnection && isSaved, current == 2),
            new WizardStep(3, "Test", "проверка доступа", isVerified, current == 3),
            new WizardStep(4, "Schema inspect", "таблицы и поля", hasSchema, current == 4),
            new WizardStep(5, "Semantic layer", "метрики и фильтры", hasSemantic, current == 5),
            new WizardStep(6, "Activate", "готово для аналитиков", isActive && isVerified, current == 6)
        };
    }

    private static bool CanActivate(CompanyDataSource? source) =>
        source?.IsVerified == true &&
        (source.IsBuiltin || !string.IsNullOrWhiteSpace(source.SemanticJson));

    private static string ActivateTitle(CompanyDataSource? source)
    {
        if (source == null)
            return "Сначала сохраните источник.";
        if (!source.IsVerified)
            return string.IsNullOrWhiteSpace(source.LastValidationError)
                ? "Сначала запустите проверку подключения."
                : source.LastValidationError;
        if (!source.IsBuiltin && string.IsNullOrWhiteSpace(source.SemanticJson))
            return "Сначала заполните semantic layer.";
        return "Активировать источник.";
    }

    private static string DataSourceStatusClass(CompanyDataSource? source) =>
        source == null ? "draft" : source.Status.Replace("_", "-", StringComparison.Ordinal);

    private static string DataSourceStatusLabel(CompanyDataSource? source) =>
        source?.Status switch
        {
            DataSourceStatuses.Active => "активен",
            DataSourceStatuses.ActiveNotVerified => "активен, не проверен",
            DataSourceStatuses.Verified => "проверен",
            DataSourceStatuses.Error => "ошибка",
            _ => "draft"
        };

    private static string FormatValidationDate(DateTime? value) =>
        value?.ToLocalTime().ToString("g") ?? "—";

    private static string DisplayText(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "—" : value;

    private sealed record WizardStep(int Number, string Title, string Subtitle, bool Done, bool Current);

    private void AuditAdmin(string action, string targetType, string? targetId = null, bool success = true, string? details = null) =>
        Audit.Record(_companyId, _adminUserId <= 0 ? null : _adminUserId, _username, action, targetType, targetId, success, details);

    private void RunAdminAction(Action action)
    {
        if (_busy)
            return;

        _busy = true;
        _notice = null;
        _error = null;
        try
        {
            action();
        }
        catch (Exception exception) when (exception is InvalidOperationException or System.Data.Common.DbException or IOException)
        {
            _error = exception.Message;
        }
        finally
        {
            _busy = false;
        }
    }
}

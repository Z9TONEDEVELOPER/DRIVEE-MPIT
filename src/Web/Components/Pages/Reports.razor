@page "/reports"
@attribute [Authorize]
@rendermode InteractiveServer
@using global::DriveeDataSpace.Web.Models
@inject global::DriveeDataSpace.Web.Services.ReportService ReportsSvc
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Drivee BI · Отчёты</PageTitle>

<div class="bi-workspace">
    <aside class="bi-sidebar">
        <div class="bi-brand">
            <div class="bi-logo">◆</div>
            <div>
                <div class="bi-brand-title">Drivee BI</div>
                <div class="bi-brand-sub">NL → SQL аналитика</div>
            </div>
        </div>

        <div class="bi-user-card">
            <div class="bi-user-label">Сеанс</div>
            <div class="bi-user-name">@_displayName</div>
            <div class="bi-user-meta">@_username · @(_isAdmin ? "Администратор" : "Пользователь")</div>
            <form method="post" action="/auth/logout">
                <button type="submit" class="bi-logout-btn">Выйти</button>
            </form>
        </div>

        <nav class="bi-nav">
            <a class="bi-nav-link" href="/"><span class="bi-nav-ico">◀</span> Workspace</a>
            <a class="bi-nav-link active" href="/reports"><span class="bi-nav-ico">▤</span> Отчёты</a>
            @if (_isAdmin)
            {
                <a class="bi-nav-link" href="/admin/data-sources"><span class="bi-nav-ico">◎</span> Источники данных</a>
                <a class="bi-nav-link" href="/admin/users"><span class="bi-nav-ico">☰</span> Пользователи</a>
            }
        </nav>

        <div class="bi-section-title">Мои отчёты</div>
        <div class="bi-reports-list">
            @if (_items.Count == 0)
            {
                <div class="bi-muted">Пока пусто</div>
            }
            else
            {
                @foreach (var report in _items.Take(8))
                {
                    <div class="bi-report-item">
                        <button class="bi-report-link" @onclick="() => Open(report.Id)" title="@report.UserQuery">@report.Name</button>
                    </div>
                }
            }
        </div>
    </aside>

    <main class="bi-chat-main">
        <header class="bi-chat-header">
            <div>
                <h1>Сохранённые отчёты</h1>
                <div class="bi-tagline">Каждый пользователь видит свои отчёты после входа в систему. Администратор дополнительно управляет доступом через раздел пользователей.</div>
            </div>
        </header>

        <div class="bi-reports-body">
            @if (_items.Count == 0)
            {
                <div class="bi-empty">Пока нет сохранённых отчётов. Перейдите в <a href="/">Workspace</a> и создайте первый.</div>
            }
            else
            {
                <div class="bi-card bi-card-table">
                    <table class="bi-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Название</th>
                                <th>Запрос</th>
                                <th>Визуализация</th>
                                <th>Автор</th>
                                <th>Создан</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var report in _items)
                            {
                                <tr>
                                    <td>@report.Id</td>
                                    <td>@report.Name</td>
                                    <td class="bi-muted">@report.UserQuery</td>
                                    <td>@report.Visualization</td>
                                    <td>@report.Author</td>
                                    <td>@report.CreatedAt.ToLocalTime().ToString("g")</td>
                                    <td>
                                        <button class="bi-btn" @onclick="() => Open(report.Id)">Открыть</button>
                                        <button class="bi-btn ghost" @onclick="() => Del(report.Id)">Удалить</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </main>
</div>

@code {
    private List<Report> _items = new();
    private string _username = "";
    private string _displayName = "";
    private bool _isAdmin;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _username = authState.User.GetUsername();
        _displayName = authState.User.GetDisplayName();
        _isAdmin = authState.User.IsAdmin();

        Load();
    }

    private void Load() => _items = ReportsSvc.ListForAuthor(_username);

    private void Open(int id) => Nav.NavigateTo($"/?report={id}");

    private void Del(int id)
    {
        ReportsSvc.DeleteForAuthor(id, _username, _isAdmin);
        Load();
    }
}

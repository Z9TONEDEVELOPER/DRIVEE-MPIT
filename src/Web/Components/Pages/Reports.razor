@page "/reports"
@rendermode InteractiveServer
@using DriveeDataSpace.Web.Models
@using Microsoft.AspNetCore.Components
@inject DriveeDataSpace.Web.Services.ReportService ReportsSvc
@inject NavigationManager Nav

<PageTitle>Drivee BI · Отчёты</PageTitle>

<div class="bi-workspace">
    <aside class="bi-sidebar">
        <div class="bi-brand">
            <div class="bi-logo">◆</div>
            <div>
                <div class="bi-brand-title">Drivee BI</div>
                <div class="bi-brand-sub">NL → SQL аналитика</div>
            </div>
        </div>

        <nav class="bi-nav">
            <a class="bi-nav-link" href="/"><span class="bi-nav-ico">◈</span> Workspace</a>
            <a class="bi-nav-link active" href="/reports"><span class="bi-nav-ico">▤</span> Отчёты</a>
        </nav>

        <div class="bi-section-title">Все отчёты</div>
        <div class="bi-reports-list">
            @if (_items.Count == 0)
            {
                <div class="bi-muted">Пока пусто</div>
            }
            else
            {
                @foreach (var r in _items)
                {
                    <div class="bi-report-item">
                        <button class="bi-report-link" @onclick="() => Open(r.Id)" title="@r.UserQuery">@r.Name</button>
                    </div>
                }
            }
        </div>
    </aside>

    <main class="bi-chat-main">
        <header class="bi-chat-header">
            <div>
                <h1>Сохранённые отчёты</h1>
                <div class="bi-tagline">Исходный запрос · интерпретация · SQL · тип визуализации. Повторное открытие заново исполняет запрос.</div>
            </div>
        </header>

        <div class="bi-reports-body">
            @if (_items.Count == 0)
            {
                <div class="bi-empty">Пока нет сохранённых отчётов. Перейдите в <a href="/">Workspace</a> и создайте первый.</div>
            }
            else
            {
                <div class="bi-card bi-card-table">
                    <table class="bi-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Название</th>
                                <th>Запрос</th>
                                <th>Визуализация</th>
                                <th>Автор</th>
                                <th>Создан</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in _items)
                            {
                                <tr>
                                    <td>@r.Id</td>
                                    <td>@r.Name</td>
                                    <td class="bi-muted">@r.UserQuery</td>
                                    <td>@r.Visualization</td>
                                    <td>@r.Author</td>
                                    <td>@r.CreatedAt.ToLocalTime().ToString("g")</td>
                                    <td>
                                        <button class="bi-btn" @onclick="() => Open(r.Id)">Открыть</button>
                                        <button class="bi-btn ghost" @onclick="() => Del(r.Id)">Удалить</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </main>
</div>

@code {
    private List<DriveeDataSpace.Web.Models.Report> _items = new();

    protected override void OnInitialized() => Load();

    private void Load() => _items = ReportsSvc.List();

    private void Open(int id) => Nav.NavigateTo($"/?report={id}");

    private void Del(int id) { ReportsSvc.Delete(id); Load(); }
}

@page "/admin/users"
@attribute [Authorize(Roles = AppRoles.AdminAccess)]
@rendermode InteractiveServer
@inject UserService Users
@inject EmailService Email
@inject AuditLogService Audit
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Nexus Data Space · Users</PageTitle>

<div class="bi-workspace">
    <aside class="bi-sidebar">
        <div class="bi-brand">
            <div class="bi-logo">◆</div>
            <div>
                <div class="bi-brand-title">Nexus Data Space</div>
                <div class="bi-brand-sub">NL → SQL аналитика</div>
            </div>
        </div>

        <div class="bi-user-card">
            <div class="bi-user-label">Сеанс</div>
            <div class="bi-user-name">@_displayName</div>
            <div class="bi-user-meta">@_username · Администратор</div>
            <form method="post" action="/auth/logout">
                <button type="submit" class="bi-logout-btn">Выйти</button>
            </form>
        </div>

        <SidebarNav Current="users" IsAdmin="true" />
    </aside>

    <main class="bi-chat-main">
        <header class="bi-chat-header">
            <div>
                <h1>Пользователи компании</h1>
                <div class="bi-tagline">Список всех учётных записей, их ролей и активности в Nexus Data Space.</div>
            </div>
        </header>

        <div class="bi-reports-body">
            @if (!string.IsNullOrWhiteSpace(_notice))
            {
                <div class="admin-notice">@_notice</div>
            }

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="admin-error">@_error</div>
            }

            <section class="admin-section">
                <div class="admin-section-head">
                    <div>
                        <h2>Компания</h2>
                        <div class="bi-tagline">Название, команда и готовность источников данных для аналитики.</div>
                    </div>
                    @if (_company != null)
                    {
                        <span class="admin-count">@_company.ActiveUserCount / @_company.UserCount активны</span>
                    }
                </div>

                <div class="bi-card company-admin-card">
                    <div class="company-admin-main">
                        <label class="company-name-field">
                            Название компании
                            <input class="auth-input" @bind="_companyNameInput" @bind:event="oninput" disabled="@_busy" />
                        </label>
                        <button type="button" class="bi-btn" @onclick="SaveCompany" disabled="@_busy">Сохранить</button>
                    </div>

                    @if (_company != null)
                    {
                        <div class="company-admin-facts">
                            <div>
                                <div class="llm-fact-label">Slug</div>
                                <div class="llm-fact-value">@_company.Slug</div>
                            </div>
                            <div>
                                <div class="llm-fact-label">Пользователи</div>
                                <div class="llm-fact-value">@_company.UserCount</div>
                                <div class="llm-fact-sub">@_company.ActiveUserCount активны</div>
                            </div>
                            <div>
                                <div class="llm-fact-label">Источники</div>
                                <div class="llm-fact-value">@_company.DataSourceCount</div>
                                <div class="llm-fact-sub">@_company.VerifiedDataSourceCount проверены</div>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <section class="admin-section">
                <div class="admin-section-head">
                    <div>
                        <h2>Заявки на доступ</h2>
                        <div class="bi-tagline">Новые пользователи появятся в системе только после одобрения администратора.</div>
                    </div>
                    <span class="admin-count">@_pendingRequests.Count ожидают</span>
                </div>

                <div class="bi-card bi-card-table">
                    @if (_pendingRequests.Count == 0)
                    {
                        <div class="bi-empty">Новых заявок нет.</div>
                    }
                    else
                    {
                        <table class="bi-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Заявитель</th>
                                    <th>Отдел или роль</th>
                                    <th>Комментарий</th>
                                    <th>Создана</th>
                                    <th>Решение</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var request in _pendingRequests)
                                {
                                    <tr>
                                        <td>@request.Id</td>
                                        <td>
                                            <div class="admin-user-name">@request.DisplayName</div>
                                            <div class="admin-user-sub">@request.Email</div>
                                        </td>
                                        <td>@DisplayText(request.Organization)</td>
                                        <td class="admin-comment">@DisplayText(request.Comment)</td>
                                        <td>@request.CreatedAt.ToLocalTime().ToString("g")</td>
                                        <td class="admin-actions-cell">
                                            <div class="admin-request-actions">
                                                <button class="bi-btn" disabled="@_busy" @onclick="() => Approve(request.Id)">Одобрить</button>
                                                <button class="bi-btn danger" disabled="@_busy" @onclick="() => Reject(request.Id)">Отклонить</button>
                                            </div>
                                            <input
                                                class="admin-reject-reason"
                                                placeholder="Причина отказа"
                                                value="@GetRejectionReason(request.Id)"
                                                @oninput="eventArgs => SetRejectionReason(request.Id, eventArgs.Value?.ToString() ?? string.Empty)" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </section>

            <section class="admin-section">
                <div class="admin-section-head">
                    <div>
                        <h2>Пользователи</h2>
                        <div class="bi-tagline">Активные учётные записи, роли и активность в Nexus Data Space.</div>
                    </div>
                    <span class="admin-count">@_users.Count всего</span>
                </div>

            <div class="bi-card bi-card-table">
                <table class="bi-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Пользователь</th>
                            <th>Email</th>
                            <th>Роль</th>
                            <th>Отчётов</th>
                            <th>Последний вход</th>
                            <th>Создан</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _users)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>
                                    <div class="admin-user-name">@item.DisplayName</div>
                                    <div class="admin-user-sub">@item.Username</div>
                                </td>
                                <td>@(item.Email ?? "—")</td>
                                <td>
                                    <select class="admin-role-select @RoleClass(item.Role)"
                                            value="@item.Role"
                                            disabled="@_busy"
                                            @onchange="eventArgs => ChangeUserRole(item.Id, eventArgs.Value?.ToString() ?? AppRoles.Analyst)">
                                        @foreach (var role in AppRoles.All)
                                        {
                                            <option value="@role">@role</option>
                                        }
                                    </select>
                                </td>
                                <td>@item.ReportCount</td>
                                <td>@FormatDate(item.LastLoginAt)</td>
                                <td>@item.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td>
                                    <button class="bi-btn ghost" @onclick="() => OpenUser(item.Id)">Открыть</button>
                                    <button class="bi-btn @(item.IsActive ? "danger" : "")"
                                            disabled="@(_busy || item.Id == _adminUserId)"
                                            @onclick="() => SetUserActive(item.Id, !item.IsActive)">
                                        @(item.IsActive ? "Отключить" : "Включить")
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            </section>

            <section class="admin-section">
                <div class="admin-section-head">
                    <div>
                        <h2>Локальные уведомления</h2>
                        <div class="bi-tagline">Последние сообщения, которые локально имитируют email-уведомления пользователям.</div>
                    </div>
                    <span class="admin-count">@_localEmails.Count писем</span>
                </div>

                <div class="bi-card bi-card-table">
                    @if (_localEmails.Count == 0)
                    {
                        <div class="bi-empty">Локальных уведомлений пока нет.</div>
                    }
                    else
                    {
                        <table class="bi-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Получатель</th>
                                    <th>Тема</th>
                                    <th>Текст</th>
                                    <th>Создано</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var email in _localEmails)
                                {
                                    <tr>
                                        <td>@email.Id</td>
                                        <td>@email.To</td>
                                        <td>
                                            <div class="admin-user-name">@email.Subject</div>
                                            <div class="admin-user-sub">@email.Category</div>
                                        </td>
                                        <td class="admin-email-body">@email.Body</td>
                                        <td>@email.CreatedAt.ToLocalTime().ToString("g")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </section>
        </div>
    </main>
</div>

@code {
    private List<AppUserSummary> _users = new();
    private List<RegistrationRequest> _pendingRequests = new();
    private List<LocalEmailMessage> _localEmails = new();
    private readonly Dictionary<int, string> _rejectionReasons = new();
    private Company? _company;
    private string _companyNameInput = "";
    private string _username = "";
    private string _displayName = "";
    private int _companyId = CompanyDefaults.DefaultCompanyId;
    private int _adminUserId;
    private bool _busy;
    private string? _notice;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _username = authState.User.GetUsername();
        _displayName = authState.User.GetDisplayName();
        _companyId = authState.User.GetCompanyId();
        _adminUserId = authState.User.GetUserId() ?? 0;
        Refresh();
    }

    private void OpenUser(int id) => Navigation.NavigateTo($"/admin/users/{id}");

    private void SaveCompany()
    {
        if (_busy)
            return;

        _busy = true;
        _notice = null;
        _error = null;
        try
        {
            _company = Users.UpdateCompany(_companyId, _companyNameInput);
            _companyNameInput = _company.Name;
            Audit.Record(_companyId, _adminUserId, _username, "company.update", "company", _companyId.ToString(), success: true, details: _company.Name);
            _notice = "Компания обновлена.";
        }
        catch (Exception exception) when (exception is InvalidOperationException)
        {
            _error = exception.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void ChangeUserRole(int userId, string role)
    {
        if (_busy)
            return;

        _busy = true;
        _notice = null;
        _error = null;
        try
        {
            var user = Users.UpdateUserRole(_companyId, userId, role);
            Audit.Record(_companyId, _adminUserId, _username, "user.role.update", "user", userId.ToString(), success: true, details: user.Role);
            _notice = $"Роль пользователя `{user.DisplayName}` обновлена: {user.Role}.";
            Refresh();
        }
        catch (Exception exception) when (exception is InvalidOperationException)
        {
            _error = exception.Message;
            Refresh();
        }
        finally
        {
            _busy = false;
        }
    }

    private void SetUserActive(int userId, bool isActive)
    {
        if (_busy)
            return;

        _busy = true;
        _notice = null;
        _error = null;
        try
        {
            var user = Users.SetUserActive(_companyId, userId, isActive);
            Audit.Record(_companyId, _adminUserId, _username, isActive ? "user.activate" : "user.deactivate", "user", userId.ToString(), success: true);
            _notice = isActive
                ? $"Пользователь `{user.DisplayName}` включён."
                : $"Пользователь `{user.DisplayName}` отключён.";
            Refresh();
        }
        catch (Exception exception) when (exception is InvalidOperationException)
        {
            _error = exception.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task Approve(int requestId)
    {
        if (_busy)
            return;

        _busy = true;
        _notice = null;
        _error = null;

        try
        {
            var result = Users.ApproveRegistrationRequest(_companyId, requestId, _adminUserId);
            Audit.Record(_companyId, _adminUserId, _username, "registration.approve", "registration_request", requestId.ToString(), success: true);
            _notice = $"Заявка #{requestId} одобрена.";
            try
            {
                await Email.SendRegistrationApprovedAsync(result.Request);
                _notice += " Локальное уведомление сохранено в outbox.";
            }
            catch (Exception exception)
            {
                _notice += $" Решение сохранено, но письмо не отправлено: {exception.Message}";
            }

            Refresh();
        }
        catch (Exception exception) when (exception is InvalidOperationException)
        {
            _error = exception.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task Reject(int requestId)
    {
        if (_busy)
            return;

        _busy = true;
        _notice = null;
        _error = null;

        try
        {
            var result = Users.RejectRegistrationRequest(_companyId, requestId, _adminUserId, GetRejectionReason(requestId));
            Audit.Record(_companyId, _adminUserId, _username, "registration.reject", "registration_request", requestId.ToString(), success: true);
            _notice = $"Заявка #{requestId} отклонена.";
            try
            {
                await Email.SendRegistrationRejectedAsync(result.Request);
                _notice += " Локальное уведомление сохранено в outbox.";
            }
            catch (Exception exception)
            {
                _notice += $" Решение сохранено, но письмо не отправлено: {exception.Message}";
            }

            Refresh();
        }
        catch (Exception exception) when (exception is InvalidOperationException)
        {
            _error = exception.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void Refresh()
    {
        _company = Users.GetCompany(_companyId);
        _companyNameInput = _company.Name;
        _users = Users.ListUsers(_companyId);
        _pendingRequests = Users.ListRegistrationRequests(_companyId, RegistrationRequestStatuses.Pending);
        _localEmails = Email.ListLocalEmails();
        foreach (var requestId in _rejectionReasons.Keys.Except(_pendingRequests.Select(request => request.Id)).ToList())
            _rejectionReasons.Remove(requestId);
    }

    private string GetRejectionReason(int requestId) =>
        _rejectionReasons.TryGetValue(requestId, out var reason) ? reason : "";

    private void SetRejectionReason(int requestId, string value) =>
        _rejectionReasons[requestId] = value;

    private static string DisplayText(string value) =>
        string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string FormatDate(DateTime? value) =>
        value?.ToLocalTime().ToString("g") ?? "—";

    private static string RoleClass(string role) =>
        AppRoles.Normalize(role).ToLowerInvariant();
}

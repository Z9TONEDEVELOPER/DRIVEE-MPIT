@page "/admin/users/{Id:int}"
@attribute [Authorize(Roles = AppRoles.AdminAccess)]
@rendermode InteractiveServer
@inject UserService Users
@inject AuditLogService Audit
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Nexus Data Space · User</PageTitle>

<div class="bi-workspace">
    <aside class="bi-sidebar">
        <div class="bi-brand">
            <div class="bi-logo">◆</div>
            <div>
                <div class="bi-brand-title">Nexus Data Space</div>
                <div class="bi-brand-sub">NL → SQL аналитика</div>
            </div>
        </div>

        <div class="bi-user-card">
            <div class="bi-user-label">Сеанс</div>
            <div class="bi-user-name">@_adminDisplayName</div>
            <div class="bi-user-meta">@_adminUsername · Администратор</div>
            <form method="post" action="/auth/logout">
                <button type="submit" class="bi-logout-btn">Выйти</button>
            </form>
        </div>

        <SidebarNav Current="users" IsAdmin="true" />
    </aside>

    <main class="bi-chat-main">
        <header class="bi-chat-header">
            <div>
                <h1>@(_user?.DisplayName ?? "Пользователь не найден")</h1>
                <div class="bi-tagline">Карточка пользователя, роль, активность и последние сохранённые отчёты.</div>
            </div>
        </header>

        @if (_user == null)
        {
            <div class="bi-empty">Пользователь с id = @Id не найден.</div>
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(_notice))
            {
                <div class="admin-notice">@_notice</div>
            }

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="admin-error">@_error</div>
            }

            <div class="admin-grid">
                <section class="bi-card">
                    <div class="bi-card-title">Профиль</div>
                    <div class="admin-facts">
                        <div><strong>Логин:</strong> @_user.Username</div>
                        <div><strong>Email:</strong> @(_user.Email ?? "—")</div>
                        <div><strong>Роль:</strong> @_user.Role</div>
                        <div><strong>Статус:</strong> @(_user.IsActive ? "Активен" : "Отключён")</div>
                        <div><strong>Создан:</strong> @_user.CreatedAt.ToLocalTime().ToString("g")</div>
                        <div><strong>Последний вход:</strong> @FormatDate(_user.LastLoginAt)</div>
                        <div><strong>Сохранённых отчётов:</strong> @_user.ReportCount</div>
                    </div>
                    <div class="admin-profile-actions">
                        <label>
                            Роль
                            <select class="auth-input" value="@_user.Role" disabled="@_busy" @onchange="ChangeRole">
                                @foreach (var role in AppRoles.All)
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                        </label>
                        <button class="bi-btn @(_user.IsActive ? "danger" : "")"
                                disabled="@(_busy || _user.Id == _adminUserId)"
                                @onclick="ToggleActive">
                            @(_user.IsActive ? "Отключить пользователя" : "Включить пользователя")
                        </button>
                    </div>
                </section>

                <section class="bi-card bi-card-table">
                    <div class="bi-card-title">Последние отчёты</div>
                    @if (_user.RecentReports.Count == 0)
                    {
                        <div class="bi-muted">Пользователь пока не сохранял отчёты.</div>
                    }
                    else
                    {
                        <table class="bi-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Название</th>
                                    <th>Запрос</th>
                                    <th>Визуализация</th>
                                    <th>Создан</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var report in _user.RecentReports)
                                {
                                    <tr>
                                        <td>@report.Id</td>
                                        <td>@report.Name</td>
                                        <td class="bi-muted">@report.UserQuery</td>
                                        <td>@report.Visualization</td>
                                        <td>@report.CreatedAt.ToLocalTime().ToString("g")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </section>
            </div>
        }
    </main>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private AppUserDetail? _user;
    private string _adminUsername = "";
    private string _adminDisplayName = "";
    private int _companyId = CompanyDefaults.DefaultCompanyId;
    private int _adminUserId;
    private bool _busy;
    private string? _notice;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _adminUsername = authState.User.GetUsername();
        _adminDisplayName = authState.User.GetDisplayName();
        _companyId = authState.User.GetCompanyId();
        _adminUserId = authState.User.GetUserId() ?? 0;
        _user = Users.GetUserDetail(_companyId, Id);
    }

    private void ChangeRole(ChangeEventArgs eventArgs)
    {
        if (_user == null || _busy)
            return;

        _busy = true;
        _notice = null;
        _error = null;
        try
        {
            _user = Users.UpdateUserRole(_companyId, _user.Id, eventArgs.Value?.ToString() ?? AppRoles.Analyst);
            Audit.Record(_companyId, _adminUserId, _adminUsername, "user.role.update", "user", _user.Id.ToString(), success: true, details: _user.Role);
            _notice = "Роль обновлена.";
        }
        catch (Exception exception) when (exception is InvalidOperationException)
        {
            _error = exception.Message;
            _user = Users.GetUserDetail(_companyId, Id);
        }
        finally
        {
            _busy = false;
        }
    }

    private void ToggleActive()
    {
        if (_user == null || _busy)
            return;

        _busy = true;
        _notice = null;
        _error = null;
        try
        {
            var nextState = !_user.IsActive;
            _user = Users.SetUserActive(_companyId, _user.Id, nextState);
            Audit.Record(_companyId, _adminUserId, _adminUsername, nextState ? "user.activate" : "user.deactivate", "user", _user.Id.ToString(), success: true);
            _notice = nextState ? "Пользователь включён." : "Пользователь отключён.";
        }
        catch (Exception exception) when (exception is InvalidOperationException)
        {
            _error = exception.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private static string FormatDate(DateTime? value) =>
        value?.ToLocalTime().ToString("g") ?? "—";
}

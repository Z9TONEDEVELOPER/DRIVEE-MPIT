@using global::NexusDataSpace.Core.Models
@using global::NexusDataSpace.Web.Models
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="chart-block">
    <div class="chart-wrap">
        <canvas id="@_chartId" @ref="_canvas"></canvas>
    </div>
    @if (Type != "pie")
    {
        <div class="chart-toolbar">
            <span class="chart-hint" title="Колесо — зум по X, перетаскивание — панорамирование, Shift+выделение — зум по области">
                Колесо · drag · Shift+выделение
            </span>
            <button class="chart-reset" @onclick="ResetZoom" title="Сбросить масштаб">Сброс</button>
        </div>
    }
</div>

@code {
    [Parameter] public global::NexusDataSpace.Core.Models.QueryResult? Result { get; set; }
    [Parameter] public string Type { get; set; } = "bar";
    [Parameter] public string Title { get; set; } = "";

    private ElementReference _canvas;
    private string _chartId = "chart-" + Guid.NewGuid().ToString("N");
    private QueryResult? _lastRenderedResult;
    private string? _lastRenderedType;
    private string? _lastRenderedTitle;
    private bool _shouldRenderChart = true;

    protected override void OnParametersSet()
    {
        _shouldRenderChart =
            !ReferenceEquals(_lastRenderedResult, Result) ||
            !string.Equals(_lastRenderedType, Type, StringComparison.Ordinal) ||
            !string.Equals(_lastRenderedTitle, Title, StringComparison.Ordinal);
    }

    protected override bool ShouldRender() => _shouldRenderChart;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Result == null || Result.Columns.Count < 1 || Result.Rows.Count == 0)
        {
            _lastRenderedResult = Result;
            _lastRenderedType = Type;
            _lastRenderedTitle = Title;
            _shouldRenderChart = false;
            return;
        }

        string[] labels;
        double[] values;

        if (Result.Columns.Count >= 2)
        {
            labels = Result.Rows.Select(r => r[0]?.ToString() ?? "").ToArray();
            values = Result.Rows.Select(r => ToDouble(r[1])).ToArray();
        }
        else
        {
            labels = new[] { Result.Columns[0] };
            values = new[] { ToDouble(Result.Rows[0][0]) };
        }

        try
        {
            await JS.InvokeVoidAsync("nexusDataSpaceCharts.render", _chartId, Type, labels, values, Title);
        }
        catch (JSException) { }
        finally
        {
            _lastRenderedResult = Result;
            _lastRenderedType = Type;
            _lastRenderedTitle = Title;
            _shouldRenderChart = false;
        }
    }

    private async Task ResetZoom()
    {
        try { await JS.InvokeVoidAsync("nexusDataSpaceCharts.resetZoom", _chartId); } catch { }
    }

    private static double ToDouble(object? v) => v switch
    {
        null => 0,
        double d => d,
        float f => f,
        decimal m => (double)m,
        long l => l,
        int i => i,
        _ => double.TryParse(v.ToString(), out var r) ? r : 0
    };

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("nexusDataSpaceCharts.destroy", _chartId); } catch { }
    }
}

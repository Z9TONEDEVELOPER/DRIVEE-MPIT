<nav class="bi-nav" aria-label="Основное меню">
    <a class="@NavClass("workspace")" href="/"><span class="bi-nav-ico">◀</span> Workspace</a>
    <a class="@NavClass("reports")" href="/reports"><span class="bi-nav-ico">▤</span> Отчёты</a>

    @if (IsAdmin)
    {
        <div class="bi-nav-group" role="group" aria-label="Настройки">
            <div class="bi-nav-group-title">Настройки</div>
            <a class="@NavClass("data-sources")" href="/admin/data-sources"><span class="bi-nav-ico">◎</span> Источники данных</a>
            <a class="@NavClass("users")" href="/admin/users"><span class="bi-nav-ico">☰</span> Пользователи</a>
            <a class="@NavClass("metrics")" href="/admin/metrics"><span class="bi-nav-ico">▤</span> Нагрузка и аудит</a>
        </div>
    }
</nav>

@code {
    [Parameter] public string Current { get; set; } = "";
    [Parameter] public bool IsAdmin { get; set; }

    private string NavClass(string key) =>
        string.Equals(Current, key, StringComparison.OrdinalIgnoreCase)
            ? "bi-nav-link active"
            : "bi-nav-link";
}

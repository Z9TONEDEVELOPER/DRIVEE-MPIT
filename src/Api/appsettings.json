{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Llm": {
    "Provider": "Local",
    "Endpoint": "http://localhost:1234/api/v1/chat",
    "Model": "qwen2.5-coder-7b-instruct",
    "TimeoutSeconds": 60,
    "MaxHistoryTurns": 2,
    "MaxOutputTokens": 700,
    "Temperature": 0,
    "FastHeuristicEnabled": true,
    "FastHeuristicConfidenceThreshold": 0.7,
    "Fallback": {
      "Provider": "",
      "GigaChat": {
        "AuthorizationKey": "",
        "Scope": "GIGACHAT_API_PERS",
        "AuthUrl": "https://ngw.devices.sberbank.ru:9443/api/v2/oauth",
        "BaseUrl": "https://gigachat.devices.sberbank.ru/api/v1",
        "Model": "GigaChat"
      }
    }
  },
  "Auth": {
    "ApiTokenSigningKey": "nexus-data-space-local-dev-token-signing-key-change-me",
    "ApiTokenLifetimeHours": 12,
    "SeedUsers": [
      {
        "Username": "admin",
        "DisplayName": "Company Administrator",
        "Password": "ChangeMe123!",
        "Role": "Admin"
      },
      {
        "Username": "analyst",
        "DisplayName": "Business Analyst",
        "Password": "ChangeMe123!",
        "Role": "User"
      }
    ]
  },
  "Data": {
    "MetadataProvider": "sqlite",
    "AnalyticsDb": "Data/nexus-data-space.db",
    "ReportsDb": "Data/reports.db",
    "DatasetCsvPath": "Data/train.csv",
    "MaxRows": 10000,
    "CommandTimeoutSeconds": 30
  },
  "Load": {
    "UserQueriesPerMinute": 12,
    "CompanyQueriesPerMinute": 60,
    "RateLimitWindowSeconds": 60,
    "MaxConcurrentLocalLlmRequests": 1,
    "MaxConcurrentGigaChatRequests": 4,
    "MaxConcurrentSqlQueries": 4,
    "BackgroundQueryWorkers": 2,
    "BackgroundQueryQueueCapacity": 100,
    "LlmQueueTimeoutSeconds": 10,
    "SqlQueueTimeoutSeconds": 8,
    "IntentCacheSeconds": 300,
    "ResultCacheSeconds": 60,
    "MaxCacheEntries": 300
  },
  "Retention": {
    "AuditLogDays": 90,
    "ReportsDays": 365
  }
}
